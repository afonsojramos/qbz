// Typography scale — font sizes and weights.

export global Typography {
    out property <length> legal: 12px;
    out property <length> link: 13px;
    out property <length> body: 14px;
    out property <length> subtitle: 14px;
    out property <length> button: 16px;
    out property <length> heading: 18px;
    out property <length> title: 24px;
    out property <length> wordmark: 28px;

    out property <int> regular: 400;
    out property <int> medium: 500;
    out property <int> semibold: 600;
    out property <int> bold: 700;
}
