// Active theme mode — the single switch that swaps the semantic palette.
// Kept in foundation (not state.slint) so semantic-colors.slint can read it
// without a circular import. Set from Settings > Appearance > Theme.
//
//   0 = Dark (default)   1 = OLED Black   2 = Tokyo Night   3 = System
//
// "System" (3) sources colors from the std-widgets Palette (OS light/dark).
// The Appearance dropdown lists only these ported themes.
export global ThemeState {
    in-out property <int> mode: 0;
}
