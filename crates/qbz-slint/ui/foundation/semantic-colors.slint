// Semantic color tokens — the contract every component consumes.
//
// The implementation moved to `theme.slint` (a Rust-driven dumb sink: one
// `ThemeColors` struct pushed in per theme change, instead of per-token
// ternaries on `ThemeState.mode`). This file is kept as the stable public
// import path: the ~150 components that `import { Theme } from
// "semantic-colors.slint"` keep working unchanged. New code may import from
// either path.
//
// Token names are identical to before; System mode still follows the OS
// std-widgets Palette (handled inside `theme.slint` via `Theme.is-system`).

export { Theme, ThemeColors } from "theme.slint";
