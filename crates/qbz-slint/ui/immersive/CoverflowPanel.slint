// Coverflow foreground (Immersive mode 2) — a CHEAP "rocola" (jukebox)
// PYRAMID of flat scaled cards.
//
// OWNER DECISION (binding, REPLACES the old true-3D-aspiring fan): NO rotateY /
// skew / perspective / reflection, NO far-edge shade gradient, NO transparency
// on the card root. Just flat scaled cards. Depth reads from (a) a step-down
// SCALE so the silhouette is a pyramid (center tallest) and (b) a per-depth
// semi-transparent BLACK overlay on an INNER rectangle (attenuation, darker
// the further out). A real blur is too expensive and is NOT used — the owner
// said "un blur o atenuación... basta", so attenuation + scale is the depth cue.
//
// LAYOUT: 7 cards = 3 past (left, history) + center + 3 upcoming (right). The
// now-playing cover is ALWAYS centered and ALWAYS on top in Z (declared LAST =
// paints last). Cards may overlap toward the center (jukebox stack).
//
// PERF: the old version animated x / width / height over 500ms on every slot,
// re-laying-out clipped images each frame on every click. That is DROPPED — the
// cards snap to their new depth on a click (Option A). Combined with the Rust
// decoded-handle reuse (queue.rs) the covers no longer blink, so the snap is
// clean. A single 120ms opacity cross-fade on the INNER dim overlay (Option B)
// is the only motion — GPU-only, no relayout, no texture re-upload.
//
// SLINT GOTCHAS honored: `parent` is never read in any root binding (viewport
// dims passed as props; CoverSlot dims passed as props). Hand-placed fixed
// instances (no Repeater) and NO `changed x/y/width/height` watchers -> avoids
// the "Recursion detected" panic. `dim` is applied on an INNER Rectangle, never
// the slot root opacity (root opacity corrupts absolute positioning). The
// off-clamp uses Math.min (max-width is ignored on hand-positioned Rectangles).
//
// DATA MAPPING (unfiltered coverflow lists, correct regardless of sidebar
// page/search — populated in queue.rs refresh_async from state.upcoming[..3] /
// state.history[..3] with decoded-handle reuse):
//   center  (depth 0)  <- NowPlayingState (unified source, also feeds the card)
//   right-n (depth n)   <- QueueState.coverflow-upcoming[n-1]  (next tracks)
//   left-n  (depth n)   <- QueueState.coverflow-history[n-1]   (recent-first)
// Side covers navigate via QueueState.play-upcoming / play-history (index n-1);
// the center is non-interactive.

import { QualityBadgeFull } from "../primitives/QualityBadgeFull.slint";
import { NowPlayingState, QueueState } from "../state.slint";

// Four-bar "now playing" equalizer. Continuous loop driven by the global
// animation-tick() (pull-based) — NOT a Timer. Verbatim copy of the
// StaticPanel.slint EqualizerBars; duplicated on purpose so this session does
// not touch the siblings. (Follow-up: lift into a shared EqualizerBars.slint.)
component EqualizerBars inherits Rectangle {
    in property <color> tint: #7c3aed;
    width: 18px;
    height: 14px;

    property <float> t: Math.mod(animation-tick() / 1ms, 800.0) / 800.0;
    function wave(phase: float) -> float {
        return 0.3 + 0.7 * (0.5 - 0.5 * Math.cos((Math.mod(self.t + phase, 1.0)) * 6.283185 * 1rad));
    }

    HorizontalLayout {
        alignment: start;
        spacing: 2px;
        Rectangle {
            width: 3px;
            y: parent.height - self.height;
            height: parent.height * 0.6 * root.wave(0.0);
            border-radius: 1px;
            background: root.tint;
        }
        Rectangle {
            width: 3px;
            y: parent.height - self.height;
            height: parent.height * 1.0 * root.wave(0.25);
            border-radius: 1px;
            background: root.tint;
        }
        Rectangle {
            width: 3px;
            y: parent.height - self.height;
            height: parent.height * 0.4 * root.wave(0.125);
            border-radius: 1px;
            background: root.tint;
        }
        Rectangle {
            width: 3px;
            y: parent.height - self.height;
            height: parent.height * 0.8 * root.wave(0.375);
            border-radius: 1px;
            background: root.tint;
        }
    }
}

// One flat card in the pyramid. Dims passed as props (NEVER `parent` in the
// root binding). `dim` is the per-depth attenuation (0 center .. 0.55 outermost)
// applied on an INNER Rectangle, never the root opacity. `has-art` is true when
// the cover image is resolved; otherwise a neutral placeholder shows instead of
// a 0-size collapse. NO animated geometry — the card snaps to its depth on a
// click; only the dim overlay cross-fades (120ms, GPU-only).
component CoverSlot inherits Rectangle {
    in property <image> art;
    in property <length> slot-size;
    in property <length> center-x;     // window-x of the cover CENTER
    in property <length> stage-height;
    in property <float> dim: 0.0;       // 0..1 per-depth black-overlay opacity
    in property <bool> has-art: false;  // art image resolved (width > 0)
    in property <bool> interactive: false;
    callback navigate();

    width: root.slot-size;
    height: root.slot-size;
    x: root.center-x - root.slot-size / 2;
    // Shared center band; the larger center card naturally rises. Small upward
    // bias to leave room for the song card below.
    y: (root.stage-height - root.slot-size) / 2 - 12px;
    border-radius: 8px;
    clip: true;

    // Static drop-shadow on the center card only (never animated, never on the
    // side cards — the attenuation carries their depth).
    drop-shadow-blur: root.dim == 0.0 ? 28px : 0px;
    drop-shadow-color: #00000066;
    drop-shadow-offset-y: root.dim == 0.0 ? 8px : 0px;

    // Neutral placeholder when the item exists but its art is unresolved.
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: 8px;
        background: #ffffff14;
        visible: !root.has-art;
    }

    Image {
        source: root.art;
        image-fit: cover;
        width: parent.width;
        height: parent.height;
        visible: root.has-art;
    }

    // Per-depth attenuation — a semi-transparent BLACK overlay on an INNER
    // Rectangle (never the slot root opacity). The ONLY animation: a short
    // opacity cross-fade so the attenuation eases as a card changes depth.
    // GPU-only (no relayout, no clipped-image re-raster) -> no CPU spike.
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: 8px;
        background: #000000;
        opacity: root.dim;
        animate opacity { duration: 120ms; easing: ease-out; }
    }

    // Side cards navigate; the center is non-interactive.
    if root.interactive: TouchArea {
        mouse-cursor: pointer;
        clicked => { root.navigate(); }
    }
}

export component CoverflowPanel inherits Rectangle {
    in property <length> viewport-width: 1280px;
    in property <length> viewport-height: 720px;

    width: root.viewport-width;
    height: root.viewport-height;
    background: transparent;

    // --- Geometry --------------------------------------------------------
    // Center cover edge (base-art = depth-0 scale). Honors the 132px player
    // clearance: reserve = pad-top(52) + info + clearance(132) = 364px.
    property <length> base-art: Math.max(160px,
        Math.min(Math.min(root.viewport-height - 364px, root.viewport-width * 0.42), 440px));

    // Step-down SCALE (center tallest): depth0 1.00, depth1 0.80, depth2 0.64,
    // depth3 0.50.
    property <length> size1: root.base-art * 0.80;
    property <length> size2: root.base-art * 0.64;
    property <length> size3: root.base-art * 0.50;

    // X offsets (center-anchored, overlapping inward). Spec ratios off1 0.42,
    // off2 0.74, off3 1.02. Each clamped so the card stays inside the half-window
    // with a 16px margin (Math.min — max-width is ignored on hand-positioned
    // rects). Chain off1 < off2 < off3 so the order never crosses.
    property <length> half-w: root.viewport-width / 2;
    property <length> off3: Math.min(root.base-art * 1.02,
        Math.max(0px, root.half-w - root.size3 / 2 - 16px));
    property <length> off2: Math.min(root.base-art * 0.74,
        Math.max(0px, root.off3 - root.size3 / 4));
    property <length> off1: Math.min(root.base-art * 0.42,
        Math.max(0px, root.off2 - root.size2 / 4));

    // --- Center artwork source (unified NowPlayingState, like the siblings) --
    property <image> center-art: NowPlayingState.artwork-large.width > 0
        ? NowPlayingState.artwork-large
        : NowPlayingState.artwork;
    property <bool> center-has-art: root.center-art.width > 0;

    // --- Side item presence (unfiltered coverflow lists) ----------------
    property <bool> has-up1: QueueState.coverflow-upcoming.length > 0;
    property <bool> has-up2: QueueState.coverflow-upcoming.length > 1;
    property <bool> has-up3: QueueState.coverflow-upcoming.length > 2;
    property <bool> has-hist1: QueueState.coverflow-history.length > 0;
    property <bool> has-hist2: QueueState.coverflow-history.length > 1;
    property <bool> has-hist3: QueueState.coverflow-history.length > 2;

    // --- Pyramid stage ---------------------------------------------------
    fan := Rectangle {
        x: 0px;
        y: 52px;                       // pad-top, matches the siblings
        width: root.viewport-width;
        height: root.base-art + 56px;

        property <length> cx: root.viewport-width / 2;

        // Declaration order = paint order: depth3 -> depth1 outward-to-inward,
        // CENTER LAST (on top). Left/right of each depth interleaved.
        // depth3 LEFT <- history[2]
        CoverSlot {
            slot-size: root.size3;
            center-x: parent.cx - root.off3;
            stage-height: parent.height;
            dim: 0.55;
            art: root.has-hist3 ? QueueState.coverflow-history[2].artwork : root.center-art;
            has-art: root.has-hist3 && QueueState.coverflow-history[2].artwork.width > 0;
            interactive: root.has-hist3;
            visible: root.has-hist3;
            navigate => { QueueState.play-history(2); }
        }
        // depth3 RIGHT <- upcoming[2]
        CoverSlot {
            slot-size: root.size3;
            center-x: parent.cx + root.off3;
            stage-height: parent.height;
            dim: 0.55;
            art: root.has-up3 ? QueueState.coverflow-upcoming[2].artwork : root.center-art;
            has-art: root.has-up3 && QueueState.coverflow-upcoming[2].artwork.width > 0;
            interactive: root.has-up3;
            visible: root.has-up3;
            navigate => { QueueState.play-coverflow-upcoming(2); }
        }
        // depth2 LEFT <- history[1]
        CoverSlot {
            slot-size: root.size2;
            center-x: parent.cx - root.off2;
            stage-height: parent.height;
            dim: 0.40;
            art: root.has-hist2 ? QueueState.coverflow-history[1].artwork : root.center-art;
            has-art: root.has-hist2 && QueueState.coverflow-history[1].artwork.width > 0;
            interactive: root.has-hist2;
            visible: root.has-hist2;
            navigate => { QueueState.play-history(1); }
        }
        // depth2 RIGHT <- upcoming[1]
        CoverSlot {
            slot-size: root.size2;
            center-x: parent.cx + root.off2;
            stage-height: parent.height;
            dim: 0.40;
            art: root.has-up2 ? QueueState.coverflow-upcoming[1].artwork : root.center-art;
            has-art: root.has-up2 && QueueState.coverflow-upcoming[1].artwork.width > 0;
            interactive: root.has-up2;
            visible: root.has-up2;
            navigate => { QueueState.play-coverflow-upcoming(1); }
        }
        // depth1 LEFT <- history[0]
        CoverSlot {
            slot-size: root.size1;
            center-x: parent.cx - root.off1;
            stage-height: parent.height;
            dim: 0.22;
            art: root.has-hist1 ? QueueState.coverflow-history[0].artwork : root.center-art;
            has-art: root.has-hist1 && QueueState.coverflow-history[0].artwork.width > 0;
            interactive: root.has-hist1;
            visible: root.has-hist1;
            navigate => { QueueState.play-history(0); }
        }
        // depth1 RIGHT <- upcoming[0]
        CoverSlot {
            slot-size: root.size1;
            center-x: parent.cx + root.off1;
            stage-height: parent.height;
            dim: 0.22;
            art: root.has-up1 ? QueueState.coverflow-upcoming[0].artwork : root.center-art;
            has-art: root.has-up1 && QueueState.coverflow-upcoming[0].artwork.width > 0;
            interactive: root.has-up1;
            visible: root.has-up1;
            navigate => { QueueState.play-coverflow-upcoming(0); }
        }
        // CENTER (depth 0) <- NowPlayingState. Declared LAST = paints on top.
        // Non-interactive, like the disabled Tauri center button.
        CoverSlot {
            slot-size: root.base-art;
            center-x: parent.cx;
            stage-height: parent.height;
            dim: 0.0;
            art: root.center-art;
            has-art: root.center-has-art;
            interactive: false;
        }
    }

    // --- Song card below the pyramid ------------------------------------
    // Reuses the StaticPanel pattern verbatim, fed by NowPlayingState. Pinned
    // under the pyramid, respecting the 132px player clearance.
    VerticalLayout {
        x: 0px;
        y: 0px;
        width: root.viewport-width;
        height: root.viewport-height;
        padding-top: 52px;
        padding-bottom: 132px;
        alignment: end;
        spacing: 6px;

        info-block := VerticalLayout {
            alignment: center;
            spacing: 6px;

            // "Now Playing" indicator — shown only while playing.
            if NowPlayingState.playing: HorizontalLayout {
                alignment: center;
                spacing: 8px;
                padding-bottom: 8px;
                VerticalLayout {
                    alignment: center;
                    EqualizerBars {
                        tint: #7c3aed;
                    }
                }
                Text {
                    text: @tr("Now Playing");
                    color: #7c3aed;
                    font-size: 12px;
                    font-weight: 600;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
            }

            Text {
                text: NowPlayingState.title;
                color: #ffffff;
                font-size: 28px;
                font-weight: 700;
                horizontal-alignment: center;
                overflow: elide;
            }
            Text {
                text: NowPlayingState.artist;
                color: #ffffffb3;
                font-size: 18px;
                horizontal-alignment: center;
                overflow: elide;
            }
            if NowPlayingState.album != "": Text {
                text: NowPlayingState.album;
                color: #ffffff80;
                font-size: 14px;
                font-italic: true;
                horizontal-alignment: center;
                overflow: elide;
            }
            HorizontalLayout {
                alignment: center;
                padding-top: 12px;
                QualityBadgeFull {
                    tier: NowPlayingState.quality-tier;
                    detail: NowPlayingState.quality-detail;
                }
            }
        }
    }
}
