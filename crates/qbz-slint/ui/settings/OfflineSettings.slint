// Settings > Offline Playback (cache half). Launches the Offline Cache
// Manager and offers clear-all / open-folder. The full per-album/track
// management lives in the manager; the Local-Library-dependent rows
// (show-in-library, repair) arrive with the Local Library port.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { OfflineManagerActions } from "../state.slint";

component Btn inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked();
    width: 184px;
    height: 36px;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: root.danger ? #e0564f : Theme.border-subtle;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
    Text {
        text: root.label;
        color: root.danger ? #e0564f : Theme.text-secondary;
        font-size: Typography.body;
        font-weight: Typography.medium;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component OfflineSettings inherits VerticalLayout {
    spacing: 16px;
    padding: 4px;
    Text {
        text: @tr("Offline Playback");
        color: Theme.text-primary;
        font-size: Typography.title;
        font-weight: Typography.bold;
    }
    Text {
        text: @tr("Cache Qobuz tracks for offline listening while your subscription is active. Manage what's downloaded, free up space, or change the cache size limit in the manager.");
        color: Theme.text-muted;
        font-size: Typography.body;
        wrap: word-wrap;
    }
    HorizontalLayout {
        spacing: 12px;
        alignment: start;
        Btn {
            label: @tr("Manage offline cache");
            clicked => {
                OfflineManagerActions.open();
            }
        }
        Btn {
            label: @tr("Open cache folder");
            clicked => {
                OfflineManagerActions.open-folder();
            }
        }
        Btn {
            label: @tr("Clear all");
            danger: true;
            clicked => {
                OfflineManagerActions.clear-all();
            }
        }
    }
    Rectangle { } // spacer
}
