// LabelReleasesView — the "See all releases" sub-view reached from the
// label landing's Releases carousel. A circular label header over the
// full album catalog, with a toolbar (search / group-by-artist / Hi-Res
// filter / sort) and a grid/list toggle, plus load-more pagination.
//
// The rendered set (`visible` / `grouped`) is derived in Rust from the
// loaded catalog (crate::label::derive_releases). Search is a local
// filter over the loaded catalog.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { LabelState, LabelActions, AlbumCardItem, DiscoverSection } from "../state.slint";
import { AlbumCard } from "../discover/AlbumCard.slint";
import { AlbumListRow, AlbumListHeader } from "../primitives/AlbumListRow.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { QbzSelect } from "../primitives/QbzSelect.slint";
import { ExpandableSearch } from "../primitives/ExpandableSearch.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import { NavButtons } from "../shell/NavButtons.slint";

// One half of a segmented toggle (grid/list) or a standalone toolbar
// toggle (group / Hi-Res). Identical surface to DiscoverBrowseView's.
component ToggleButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    callback clicked();

    width: 34px;
    height: 34px;
    background: root.active
        ? Theme.surface-hover
        : (ta.has-hover ? Theme.surface-elevated : transparent);

    QbzIcon {
        source: root.icon;
        width: 17px;
        height: 17px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: root.active ? Theme.text-primary : Theme.text-muted;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// Wrapping album grid over a model — shared by the flat view and each
// group-by-artist section so the column math lives in one place.
component AlbumGrid inherits Rectangle {
    in property <[AlbumCardItem]> albums;
    in property <length> card-width: 220px;
    in property <length> card-height: 266px;
    in property <length> card-gap: 24px;
    callback open-album(string);
    callback open-artist(string);
    callback media-action(string, string, string);

    property <int> columns: Math.max(
        1,
        Math.floor((self.width + root.card-gap) / (root.card-width + root.card-gap)));
    property <int> rows: Math.ceil(root.albums.length / self.columns);
    height: self.rows > 0
        ? self.rows * root.card-height + Math.max(0, self.rows - 1) * root.card-gap
        : 0px;

    for album[i] in root.albums: AlbumCard {
        x: Math.mod(i, root.columns) * (root.card-width + root.card-gap);
        y: Math.floor(i / root.columns) * (root.card-height + root.card-gap);
        width: root.card-width;
        height: root.card-height;
        album: album;
        clicked(id) => {
            root.open-album(id);
        }
        media-action(kind, id, action) => {
            if (kind == "artist") {
                root.open-artist(id);
            } else {
                root.media-action(kind, id, action);
            }
        }
    }
}

export component LabelReleasesView inherits Rectangle {
    callback open-album(string);
    callback open-artist(string);
    callback media-action(string, string, string);

    property <length> list-row-gap: 4px;

    background: Theme.surface-main;

    flick := Flickable {
        viewport-width: self.width;
        viewport-height: page.preferred-height;

        page := VerticalLayout {
            width: parent.width;
            padding-left: 32px;
            padding-right: 32px;
            padding-top: 11px;
            padding-bottom: 100px;
            spacing: 0px;
            alignment: start;

            HorizontalLayout {
                alignment: start;
                NavButtons { }
            }

            Rectangle { height: 22px; }

            // --- Label header (circular 180px portrait) ------------------
            HorizontalLayout {
                spacing: 24px;
                alignment: start;
                Rectangle {
                    width: 180px;
                    height: 180px;
                    border-radius: 90px;
                    background: Theme.surface-elevated;
                    drop-shadow-blur: 32px;
                    drop-shadow-color: #00000080;
                    drop-shadow-offset-y: 8px;
                    clip: true;
                    if LabelState.image-url == "": QbzIcon {
                        source: @image-url("../assets/icons/disc-3.svg");
                        width: 60px;
                        height: 60px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        tint: Theme.text-muted;
                    }
                    Image {
                        width: 100%;
                        height: 100%;
                        source: LabelState.image;
                        image-fit: cover;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    horizontal-stretch: 1;
                    Text {
                        text: @tr("LABEL");
                        color: Theme.text-muted;
                        font-size: 10px;
                        font-weight: Typography.semibold;
                        letter-spacing: 1.5px;
                    }
                    Text {
                        text: LabelState.name;
                        color: Theme.text-primary;
                        font-size: Typography.title;
                        font-weight: Typography.bold;
                    }
                    if LabelState.total > 0: Text {
                        text: LabelState.total + " " + @tr("albums");
                        color: Theme.text-muted;
                        font-size: Typography.body;
                    }
                }
            }

            Rectangle { height: 24px; }

            // --- Toolbar: title + count, then search / group / Hi-Res /
            // sort / grid-list (floated right) ---------------------------
            HorizontalLayout {
                spacing: 12px;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: @tr("Releases");
                        color: Theme.text-primary;
                        font-size: Typography.heading;
                        font-weight: Typography.semibold;
                    }
                    Text {
                        text: LabelState.shown + " " + @tr("albums")
                            + (LabelState.hires-count > 0
                                ? " · " + LabelState.hires-count + " Hi-Res"
                                : "");
                        color: Theme.text-muted;
                        font-size: Typography.legal;
                    }
                }
                HorizontalLayout {
                    horizontal-stretch: 0;
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        ExpandableSearch {
                            placeholder: @tr("Search this label…");
                            query <=> LabelState.search-query;
                            edited(q) => {
                                LabelActions.search(q);
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        ToggleButton {
                            icon: @image-url("../assets/icons/user.svg");
                            active: LabelState.group-by-artist;
                            clicked => {
                                LabelState.group-by-artist = !LabelState.group-by-artist;
                                LabelActions.set-group(LabelState.group-by-artist);
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        ToggleButton {
                            icon: @image-url("../assets/icons/list-filter.svg");
                            active: LabelState.filter-hires;
                            clicked => {
                                LabelState.filter-hires = !LabelState.filter-hires;
                                LabelActions.set-hires(LabelState.filter-hires);
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        QbzSelect {
                            menu-width: 168px;
                            options: [
                                @tr("Newest"),
                                @tr("Oldest"),
                                @tr("Title A-Z"),
                                @tr("Title Z-A"),
                                @tr("Artist A-Z"),
                            ];
                            current-index: LabelState.sort-by == "newest" ? 0
                                : LabelState.sort-by == "oldest" ? 1
                                : LabelState.sort-by == "title-asc" ? 2
                                : LabelState.sort-by == "title-desc" ? 3
                                : 4;
                            selected(i) => {
                                LabelState.sort-by = i == 0 ? "newest"
                                    : i == 1 ? "oldest"
                                    : i == 2 ? "title-asc"
                                    : i == 3 ? "title-desc"
                                    : "artist-asc";
                                LabelActions.set-sort(LabelState.sort-by);
                            }
                        }
                    }
                    // Grid / list segmented toggle.
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 68px;
                            height: 34px;
                            border-radius: 6px;
                            background: Theme.surface-elevated;
                            clip: true;
                            HorizontalLayout {
                                ToggleButton {
                                    icon: @image-url("../assets/icons/layout-grid.svg");
                                    active: LabelState.view-mode == "grid";
                                    clicked => {
                                        LabelState.view-mode = "grid";
                                    }
                                }
                                ToggleButton {
                                    icon: @image-url("../assets/icons/list.svg");
                                    active: LabelState.view-mode == "list";
                                    clicked => {
                                        LabelState.view-mode = "list";
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 24px; }

            // --- States --------------------------------------------------
            if LabelState.loading && LabelState.albums.length == 0: HorizontalLayout {
                alignment: center;
                LoadingSpinner { size: 36px; }
            }
            // No search/filter results.
            if !LabelState.loading && LabelState.albums.length > 0
                && LabelState.shown == 0: VerticalLayout {
                alignment: center;
                spacing: 10px;
                HorizontalLayout {
                    alignment: center;
                    QbzIcon {
                        source: @image-url("../assets/icons/search.svg");
                        width: 32px;
                        height: 32px;
                        tint: Theme.text-muted;
                    }
                }
                Text {
                    text: @tr("No results");
                    color: Theme.text-muted;
                    font-size: 14px;
                    horizontal-alignment: center;
                }
            }

            // --- Grouped by artist ---------------------------------------
            if LabelState.group-by-artist: VerticalLayout {
                spacing: 0px;
                for section[s] in LabelState.grouped: VerticalLayout {
                    spacing: 12px;
                    if s > 0: Rectangle { height: 24px; }
                    Text {
                        text: section.title;
                        color: Theme.text-primary;
                        font-size: Typography.heading;
                        font-weight: Typography.semibold;
                    }
                    AlbumGrid {
                        albums: section.albums;
                        open-album(id) => {
                            root.open-album(id);
                        }
                        open-artist(id) => {
                            root.open-artist(id);
                        }
                        media-action(kind, id, action) => {
                            root.media-action(kind, id, action);
                        }
                    }
                }
            }

            // --- Flat grid -----------------------------------------------
            if !LabelState.group-by-artist && LabelState.visible.length > 0
                && LabelState.view-mode == "grid": AlbumGrid {
                albums: LabelState.visible;
                open-album(id) => {
                    root.open-album(id);
                }
                open-artist(id) => {
                    root.open-artist(id);
                }
                media-action(kind, id, action) => {
                    root.media-action(kind, id, action);
                }
            }

            // --- Flat list -----------------------------------------------
            if !LabelState.group-by-artist && LabelState.visible.length > 0
                && LabelState.view-mode == "list": VerticalLayout {
                spacing: root.list-row-gap;
                AlbumListHeader {
                    show-source: false;
                }
                for album[i] in LabelState.visible: AlbumListRow {
                    album: album;
                    index: i;
                    show-source: false;
                    clicked(id) => {
                        root.open-album(id);
                    }
                    media-action(kind, id, action) => {
                        if (kind == "artist") {
                            root.open-artist(id);
                        } else {
                            root.media-action(kind, id, action);
                        }
                    }
                }
            }

            // --- Load more -----------------------------------------------
            if LabelState.albums.length > 0
                && LabelState.albums.length < LabelState.total: HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: load-more-text.preferred-width + 24px;
                    height: 32px;
                    load-more-text := Text {
                        text: LabelState.load-more-loading
                            ? @tr("Loading…")
                            : @tr("Load more");
                        color: load-more-ta.has-hover
                            ? Theme.text-primary
                            : Theme.text-secondary;
                        font-size: 13px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    load-more-ta := TouchArea {
                        mouse-cursor: pointer;
                        enabled: !LabelState.load-more-loading;
                        clicked => {
                            LabelActions.load-more();
                        }
                    }
                }
            }
        }
    }

    // Shared scrollbar in the right gutter (homologated cross-view).
    ListScrollbar {
        x: parent.width - self.width - 4px;
        width: 14px;
        height: 100%;
        viewport-height: flick.viewport-height;
        visible-height: flick.height;
        viewport-y <=> flick.viewport-y;
    }
}
