// One row of a context menu — an icon, a label, and a click callback.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { QbzIcon } from "QbzIcon.slint";

export component ContextMenuItem inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    // When false the row collapses to zero height and stops rendering /
    // capturing input — lets a `for` build a filtered list without an
    // inner `if` (which Slint does not allow as a direct `for` child).
    in property <bool> shown: true;
    callback clicked();

    height: root.shown ? 33px : 0px;
    visible: root.shown;
    clip: true;
    background: ta.has-hover ? Theme.surface-hover : transparent;

    HorizontalLayout {
        padding-left: 11px;
        padding-right: 16px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.icon;
                width: 15px;
                height: 15px;
                tint: ta.has-hover ? Theme.text-primary : Theme.text-secondary;
            }
        }
        Text {
            text: root.label;
            color: ta.has-hover ? Theme.text-primary : Theme.text-secondary;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}
