// CommandBlock — a copy-paste shell command / config snippet (HiFi wizard).
//
// Surface-elevated card (Radius.sm, no pills) with an optional caption, a
// monospace command body that wraps, and a copy button that flips to a green
// check for 2s. READ-ONLY: the `copy()` callback is wired by the consumer to
// the clipboard (crate::share::copy_to_clipboard); nothing is ever executed.
//
// The height is content-sized (col.preferred-height) so a multi-line command
// grows the block; callers place it in a VerticalLayout and never set a fixed
// height.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { QbzIcon } from "QbzIcon.slint";

export component CommandBlock inherits Rectangle {
    in property <string> command;
    // Optional caption rendered above the command (e.g. what it does).
    in property <string> caption: "";
    callback copy();

    property <bool> just-copied: false;

    border-radius: Radius.sm;
    background: Theme.surface-elevated;
    border-width: 1px;
    border-color: Theme.border-subtle;
    height: col.preferred-height;

    col := VerticalLayout {
        padding: 12px;
        spacing: 8px;

        if root.caption != "": Text {
            text: root.caption;
            color: Theme.text-secondary;
            font-size: Typography.legal;
            font-weight: Typography.medium;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 10px;
            // Monospace command body — wraps, takes the remaining width.
            Text {
                text: root.command;
                color: Theme.text-primary;
                font-size: Typography.legal;
                font-family: "monospace";
                wrap: word-wrap;
                horizontal-stretch: 1;
            }
            // Copy button — fixed 30x30, pinned to the top of the row.
            VerticalLayout {
                alignment: start;
                copy-btn := Rectangle {
                    width: 30px;
                    height: 30px;
                    border-radius: Radius.sm;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    background: copy-ta.has-hover ? Theme.surface-hover : Theme.surface-card;
                    QbzIcon {
                        width: 15px;
                        height: 15px;
                        source: root.just-copied
                            ? @image-url("../assets/icons/check.svg")
                            : @image-url("../assets/icons/copy.svg");
                        tint: root.just-copied
                            ? #3fae6a
                            : (copy-ta.has-hover ? Theme.text-primary : Theme.text-muted);
                    }
                    copy-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.copy();
                            root.just-copied = true;
                            reset-timer.running = true;
                        }
                    }
                }
            }
        }
    }

    // Resets the "copied" check after 2s.
    reset-timer := Timer {
        interval: 2s;
        running: false;
        triggered => {
            root.just-copied = false;
            self.running = false;
        }
    }
}
