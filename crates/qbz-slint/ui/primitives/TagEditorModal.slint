// Local-album tag editor modal. Album + per-track fields, sidecar (default)
// or opt-in direct file-write. Mounted last in AppShell so it overlays all
// chrome (ADR-009). Remote MusicBrainz/Discogs lookup is a follow-up sub-slice.
//
// Driven by TagEditorState / TagEditorActions. visible:-gated (ADR-010 modal
// pattern, like EditPlaylistModal). ADR-008: persistence picker is a QbzSelect,
// no pills.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { TagEditorState, TagEditorActions } from "../state.slint";
import { QbzIcon } from "QbzIcon.slint";
import { QbzSelect } from "QbzSelect.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

// A labeled field block (label above the control).
component Field inherits VerticalLayout {
    in property <string> label;
    spacing: 5px;
    Text {
        text: root.label;
        color: Theme.text-muted;
        font-size: Typography.legal;
        font-weight: Typography.semibold;
    }
    @children
}

export component TagEditorModal inherits Rectangle {
    visible: TagEditorState.open;

    if TagEditorState.open: Rectangle {
        background: #000000bf;
        TouchArea {
            mouse-cursor: default;
            clicked => {
                if (!TagEditorState.saving) {
                    TagEditorActions.close();
                }
            }
        }
        Rectangle {
            width: Math.min(root.width - 80px, 820px);
            height: Math.min(root.height - 80px, 720px);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: Radius.md;
            background: Theme.surface-card;
            border-width: 1px;
            border-color: Theme.border-subtle;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000080;
            TouchArea { }

            VerticalLayout {
                padding: 22px;
                spacing: 14px;

                // Header.
                HorizontalLayout {
                    Text {
                        text: @tr("Edit metadata");
                        color: Theme.text-primary;
                        font-size: Typography.heading;
                        font-weight: Typography.semibold;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    close-x := TouchArea {
                        width: 28px;
                        height: 28px;
                        mouse-cursor: pointer;
                        clicked => {
                            if (!TagEditorState.saving) {
                                TagEditorActions.close();
                            }
                        }
                        QbzIcon {
                            source: @image-url("../assets/icons/x.svg");
                            width: 17px;
                            height: 17px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            tint: close-x.has-hover ? Theme.text-primary : Theme.text-muted;
                        }
                    }
                }

                // Album title + artist.
                HorizontalLayout {
                    spacing: 12px;
                    Field {
                        label: @tr("Album title");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Album title");
                            text <=> TagEditorState.album_title;
                        }
                    }
                    Field {
                        label: @tr("Album artist");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Album artist");
                            text <=> TagEditorState.album_artist;
                        }
                    }
                }

                // Year / Genre / Catalog.
                HorizontalLayout {
                    spacing: 12px;
                    Field {
                        label: @tr("Year");
                        width: 120px;
                        LineEdit {
                            placeholder-text: "—";
                            text <=> TagEditorState.year_input;
                        }
                    }
                    Field {
                        label: @tr("Genre");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: @tr("Genre");
                            text <=> TagEditorState.genre;
                        }
                    }
                    Field {
                        label: @tr("Catalog number");
                        horizontal-stretch: 1;
                        LineEdit {
                            placeholder-text: "—";
                            text <=> TagEditorState.catalog_number;
                        }
                    }
                }

                // Total discs (collected, not persisted — rendered once).
                Text {
                    text: @tr("Total discs") + ": \{TagEditorState.album_total_discs}";
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                }

                // Track table.
                Text {
                    text: @tr("Tracks");
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    font-weight: Typography.semibold;
                }
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: Radius.sm;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    clip: true;
                    ScrollView {
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                        VerticalLayout {
                            padding: 6px;
                            spacing: 4px;
                            for row[i] in TagEditorState.tracks: HorizontalLayout {
                                spacing: 8px;
                                height: 34px;
                                // Track number.
                                LineEdit {
                                    width: 52px;
                                    placeholder-text: "#";
                                    text: row.track_number;
                                    edited(t) => {
                                        TagEditorState.tracks[i].track_number = t;
                                    }
                                }
                                // Title.
                                LineEdit {
                                    horizontal-stretch: 1;
                                    placeholder-text: @tr("Title");
                                    text: row.title;
                                    edited(t) => {
                                        TagEditorState.tracks[i].title = t;
                                    }
                                }
                                // Disc.
                                LineEdit {
                                    width: 52px;
                                    placeholder-text: @tr("Disc");
                                    text: row.disc_number;
                                    edited(t) => {
                                        TagEditorState.tracks[i].disc_number = t;
                                    }
                                }
                            }
                        }
                    }
                }

                // Album path reference.
                Text {
                    text: @tr("Album folder") + ": " + TagEditorState.directory_path;
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    overflow: elide;
                }

                // Footer: persistence picker (left) + Cancel/Save (right).
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        QbzSelect {
                            menu-width: 220px;
                            options: [
                                @tr("Sidecar file (recommended)"),
                                @tr("Write to audio files"),
                            ];
                            current-index: TagEditorState.persistence_index;
                            sm: true;
                            selected(i) => {
                                TagEditorActions.set-persistence(i);
                            }
                        }
                    }
                    // Direct-write warning / CUE-unsupported note.
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        if TagEditorState.persistence_index == 1: Text {
                            text: @tr("This writes tags directly into your audio files.");
                            color: #d8a23a;
                            font-size: Typography.legal;
                            overflow: elide;
                        }
                        if !TagEditorState.can_direct_write: Text {
                            text: @tr("Direct write is unavailable for CUE-based albums.");
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            overflow: elide;
                        }
                    }
                    // Cancel.
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: cancel-label.preferred-width + 28px;
                            height: 36px;
                            border-radius: Radius.sm;
                            background: cancel-ta.has-hover ? Theme.surface-hover : transparent;
                            border-width: 1px;
                            border-color: Theme.border-subtle;
                            opacity: TagEditorState.saving ? 0.5 : 1.0;
                            cancel-label := Text {
                                text: @tr("Cancel");
                                color: Theme.text-secondary;
                                font-size: Typography.body;
                                font-weight: Typography.medium;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                            cancel-ta := TouchArea {
                                mouse-cursor: TagEditorState.saving ? default : pointer;
                                clicked => {
                                    if (!TagEditorState.saving) {
                                        TagEditorActions.close();
                                    }
                                }
                            }
                        }
                    }
                    // Save.
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: save-label.preferred-width + 36px;
                            height: 36px;
                            border-radius: Radius.sm;
                            background: save-ta.has-hover && !TagEditorState.saving
                                ? Theme.accent-hover : Theme.accent;
                            opacity: TagEditorState.saving ? 0.6 : 1.0;
                            save-label := Text {
                                text: TagEditorState.write_progress_total > 0
                                    ? (@tr("Writing") + " \{TagEditorState.write_progress_current}/\{TagEditorState.write_progress_total}…")
                                    : (TagEditorState.saving ? @tr("Saving…") : @tr("Save"));
                                color: Theme.accent-text;
                                font-size: Typography.body;
                                font-weight: Typography.semibold;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                            save-ta := TouchArea {
                                mouse-cursor: TagEditorState.saving ? default : pointer;
                                clicked => {
                                    if (!TagEditorState.saving) {
                                        TagEditorActions.save();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
