// Artist detail page.
//
// An artwork-tinted gradient header (circular portrait, name, biography,
// action buttons), a Popular Tracks list, and the discography split into
// titled release sections (Albums, EPs & Singles, Live, ...). Data comes
// from the ArtistState global; action buttons are visual for now.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { ArtistState, AlbumTrackItem, NavState, ContentView } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { ContextMenu } from "../primitives/ContextMenu.slint";
import { ContextMenuItem } from "../primitives/ContextMenuItem.slint";
import { TrackPlayCell } from "../primitives/TrackPlayCell.slint";
import { TrackContextMenu } from "../primitives/TrackContextMenu.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import { Carousel } from "../discover/Carousel.slint";
import { NavButtons } from "../shell/NavButtons.slint";

component CircleAction inherits Rectangle {
    in property <image> icon;
    in property <bool> primary: false;
    in property <length> diameter: 40px;
    callback clicked();

    width: root.diameter;
    height: root.diameter;
    border-radius: root.diameter / 2;
    // Ghost circle — translucent fill with a faint ring, never a solid
    // accent fill (mirrors the Tauri transport controls).
    background: ta.has-hover ? Theme.surface-hover : transparent;
    border-width: 1px;
    border-color: ta.has-hover ? Theme.text-disabled : Theme.border-subtle;

    QbzIcon {
        source: root.icon;
        width: root.primary ? 19px : 17px;
        height: root.primary ? 19px : 17px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: ta.has-hover ? Theme.text-primary : Theme.text-secondary;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component TrackRow inherits Rectangle {
    in property <AlbumTrackItem> track;
    in property <int> index;
    // When true, the row shows a leading checkbox column and hides the
    // per-row hover affordances — driven by the Popular Tracks "Select"
    // header toggle, which mirrors Tauri's multiSelectMode flow.
    in property <bool> multi-select-mode: false;
    callback media-action(string, string, string);

    // Any-hover detector — Slint does not propagate has-hover to ancestor
    // TouchAreas, so OR the row TouchArea with the nested ones to drive
    // the play overlay on the cell from anywhere over the row.
    property <bool> row-hovered:
        ta.has-hover || play-cell.hovered || more-ta.has-hover;

    height: 52px;
    border-radius: 8px;
    // The even-row tint is clearly fainter than the hover tint so the two
    // never read as the same state. Use row-hovered so hovering the cell
    // or the more button keeps the row tint.
    background: root.row-hovered
        ? #ffffff16
        : (Math.mod(root.index, 2) == 1 ? #ffffff07 : transparent);

    ta := TouchArea {
        mouse-cursor: default;
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 16px;

        VerticalLayout {
            alignment: center;
            play-cell := TrackPlayCell {
                track-id: root.track.id;
                number: root.track.number;
                show-artwork: false;
                number-width: 28px;
                row-hovered: root.row-hovered;
                play => {
                    root.media-action("track", root.track.id, "play");
                }
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.track.title;
                color: Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                overflow: elide;
            }
        }
        Text {
            text: root.track.duration;
            width: 70px;
            color: Theme.text-muted;
            font-size: Typography.body;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        Text {
            text: root.track.quality-tier == "hires"
                ? "Hi-Res"
                : (root.track.quality-tier == "cd" ? "CD" : "");
            width: 70px;
            color: Theme.text-muted;
            font-size: Typography.legal;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // Select checkbox — only visible while the section is in
        // multi-select mode (toggled by the section header's Select
        // button). Mirrors Tauri's #if multiSelectMode gate.
        if root.multi-select-mode: VerticalLayout {
            alignment: center;
            Rectangle {
                width: 22px;
                height: 22px;
                border-radius: 11px;
                background: root.track.selected ? Theme.accent : transparent;
                border-width: root.track.selected ? 0px : 1.5px;
                border-color: select-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                animate background { duration: 120ms; }
                QbzIcon {
                    source: @image-url("../assets/icons/check.svg");
                    width: 14px;
                    height: 14px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: #ffffff;
                    visible: root.track.selected;
                }
                select-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.media-action("track", root.track.id, "toggle-select");
                    }
                }
            }
        }

        // More / context-menu button — always visible on Popular Tracks.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: Radius.sm;
                background: more-ta.has-hover ? Theme.surface-elevated : transparent;
                QbzIcon {
                    source: @image-url("../assets/icons/ellipsis.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: more-ta.has-hover ? Theme.text-primary : Theme.text-secondary;
                }
                more-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        track-menu.show();
                    }
                }
            }
        }
    }

    track-menu := TrackContextMenu {
        x: parent.width - self.width - 12px;
        y: 44px;
        track-id: root.track.id;
        media-action(k, i, a) => {
            root.media-action(k, i, a);
        }
    }
}

component SectionTitle inherits Text {
    color: Theme.text-primary;
    font-size: Typography.heading;
    font-weight: Typography.semibold;
}

export component ArtistPageView inherits Rectangle {
    callback open-album(string);
    callback media-action(string, string, string);

    // Read-more toggle for the biography.
    property <bool> bio-expanded: false;
    // Popular Tracks shows the first 5; Load more expands to all.
    property <bool> top-tracks-expanded: false;
    property <int> top-tracks-preview: 5;
    // Popular Tracks multi-select mode — toggled by the section header's
    // Select button. When true, each row reveals a leading checkbox column
    // (TrackRow's `multi-select-mode` prop). Mirrors Tauri's flow.
    property <bool> multi-select-mode: false;

    background: Theme.surface-main;

    Flickable {
        viewport-width: self.width;
        viewport-height: page.preferred-height;

        // Artwork-tinted gradient behind the header; scrolls with content.
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: 340px;
            background: @linear-gradient(180deg,
                ArtistState.header-color 0%,
                ArtistState.header-color 16%,
                transparent 100%);
        }

        page := VerticalLayout {
            width: parent.width;
            // padding matches Discover so the [<] [>] pair sits at the same
            // top/left margin across every view.
            padding-left: 32px;
            padding-right: 32px;
            padding-top: 11px;
            padding-bottom: 100px;
            spacing: 0px;
            alignment: start;

            // --- History navigation ------------------------------------------
            HorizontalLayout {
                alignment: start;
                NavButtons { }
            }

            Rectangle { height: 22px; }

            // --- Artist header -----------------------------------------------
            HorizontalLayout {
                spacing: 32px;
                alignment: start;

                Rectangle {
                    width: 200px;
                    height: 200px;
                    border-radius: 100px;
                    background: Theme.surface-elevated;
                    drop-shadow-blur: 32px;
                    drop-shadow-color: #00000080;
                    drop-shadow-offset-y: 8px;
                    clip: true;
                    Image {
                        width: 100%;
                        height: 100%;
                        source: ArtistState.artwork;
                        image-fit: cover;
                    }
                }

                VerticalLayout {
                    alignment: start;
                    padding-top: 8px;
                    spacing: 0px;
                    horizontal-stretch: 1;

                    Text {
                        text: @tr("ARTIST");
                        color: Theme.text-muted;
                        font-size: 10px;
                        font-weight: Typography.semibold;
                        letter-spacing: 1.5px;
                    }
                    Rectangle { height: 6px; }
                    Text {
                        text: ArtistState.name;
                        color: Theme.text-primary;
                        font-size: Typography.title;
                        font-weight: Typography.bold;
                        overflow: elide;
                    }

                    // Biography — single inline block matching Tauri's
                    // structure: truncated body + Read more/less toggle +
                    // optional "Source: <name>" line. The full text is
                    // shown when `bio-expanded` flips.
                    if ArtistState.bio != "": Rectangle { height: 12px; }
                    if ArtistState.bio != "": Text {
                        text: root.bio-expanded ? ArtistState.bio : ArtistState.bio-short;
                        color: Theme.text-secondary;
                        font-size: Typography.body;
                        wrap: word-wrap;
                    }
                    if ArtistState.bio-truncated: Rectangle {
                        height: 24px;
                        width: read-more-text.preferred-width + 16px;
                        read-more-text := Text {
                            text: root.bio-expanded ? @tr("Read less") : @tr("Read more");
                            color: read-more-ta.has-hover
                                ? Theme.text-primary
                                : Theme.accent;
                            font-size: 13px;
                            font-weight: Typography.medium;
                            vertical-alignment: center;
                            height: 100%;
                        }
                        read-more-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.bio-expanded = !root.bio-expanded;
                            }
                        }
                    }
                    if ArtistState.bio-source != "": Rectangle { height: 4px; }
                    if ArtistState.bio-source != "": Text {
                        text: @tr("Source") + ": " + ArtistState.bio-source;
                        color: Theme.text-muted;
                        font-size: 11px;
                    }

                    Rectangle { height: 18px; }

                    // Action buttons — Heart, Build collection, Radio
                    // (with QBZ / Qobuz dropdown). Mirrors Tauri's
                    // artist-actions: NO Play here (top tracks has its
                    // own play). Network sidebar toggle and Hide are
                    // deferred to Tanda 2 (sidebar work).
                    HorizontalLayout {
                        alignment: start;
                        spacing: 12px;
                        CircleAction {
                            icon: @image-url("../assets/icons/heart.svg");
                            clicked => {
                                root.media-action("artist", "", "favorite");
                            }
                        }
                        CircleAction {
                            icon: @image-url("../assets/icons/library-big.svg");
                            clicked => {
                                root.media-action("artist", "", "build-collection");
                            }
                        }
                        // Radio with dropdown — QBZ radio (local engine)
                        // vs Qobuz radio (qobuz-curated). Both call
                        // distinct media-actions; main.rs wires them.
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            CircleAction {
                                icon: @image-url("../assets/icons/radio.svg");
                                clicked => {
                                    radio-popup.show();
                                }
                            }
                            radio-popup := PopupWindow {
                                x: 0px;
                                y: 50px;
                                width: 180px;
                                close-policy: close-on-click;
                                ContextMenu {
                                    ContextMenuItem {
                                        icon: @image-url("../assets/icons/radio.svg");
                                        label: "QBZ Radio";
                                        clicked => {
                                            root.media-action("artist", "", "radio-qbz");
                                        }
                                    }
                                    ContextMenuItem {
                                        icon: @image-url("../assets/icons/radio.svg");
                                        label: "Qobuz Radio";
                                        clicked => {
                                            root.media-action("artist", "", "radio-qobuz");
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 36px; }

            if ArtistState.loading && ArtistState.top-tracks.length == 0: Rectangle {
                height: 280px;
                VerticalLayout {
                    alignment: center;
                    spacing: 18px;
                    HorizontalLayout {
                        alignment: center;
                        LoadingSpinner { size: 36px; }
                    }
                    Text {
                        text: @tr("Loading artist…");
                        color: Theme.text-muted;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                }
            }

            // --- Popular tracks ----------------------------------------------
            // Section header: title on the left, action cluster on the right
            // (Play all / Select-mode toggle / More menu). Mirrors Tauri's
            // popular-tracks section-header.
            if ArtistState.top-tracks.length > 0: HorizontalLayout {
                alignment: space-between;
                spacing: 12px;
                VerticalLayout {
                    alignment: center;
                    SectionTitle {
                        text: @tr("Popular Tracks");
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 12px;
                    CircleAction {
                        icon: @image-url("../assets/icons/play-fill.svg");
                        primary: true;
                        diameter: 40px;
                        clicked => {
                            root.media-action("artist", "", "play-top");
                        }
                    }
                    CircleAction {
                        icon: @image-url("../assets/icons/square-check-big.svg");
                        clicked => {
                            root.multi-select-mode = !root.multi-select-mode;
                        }
                    }
                    CircleAction {
                        icon: @image-url("../assets/icons/ellipsis.svg");
                        clicked => {
                            root.media-action("artist", "", "top-tracks-menu");
                        }
                    }
                }
            }
            if ArtistState.top-tracks.length > 0: Rectangle { height: 10px; }
            for track[index] in ArtistState.top-tracks: TrackRow {
                visible: root.top-tracks-expanded || index < root.top-tracks-preview;
                height: self.visible ? 52px : 0px;
                track: track;
                index: index;
                multi-select-mode: root.multi-select-mode;
                media-action(kind, id, action) => {
                    root.media-action(kind, id, action);
                }
            }
            // Load more — visible when there are more than the preview cap.
            if !root.top-tracks-expanded
                && ArtistState.top-tracks.length > root.top-tracks-preview: HorizontalLayout {
                alignment: start;
                Rectangle {
                    width: load-more-text.preferred-width + 32px;
                    height: 32px;
                    border-radius: Radius.sm;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    background: load-more-ta.has-hover
                        ? Theme.surface-elevated
                        : Theme.surface-card;
                    load-more-text := Text {
                        text: @tr("Load more");
                        color: Theme.text-secondary;
                        font-size: 13px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    load-more-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.top-tracks-expanded = true;
                        }
                    }
                }
            }

            // --- Release sections (Albums, EPs & Singles, Live, ...) ---------
            for section in ArtistState.release-sections: VerticalLayout {
                spacing: 0px;
                Rectangle { height: 32px; }
                Carousel {
                    section: section;
                    album-clicked(id) => {
                        root.open-album(id);
                    }
                    media-action(kind, id, action) => {
                        root.media-action(kind, id, action);
                    }
                }
            }
        }
    }
}
