// Sidebar-collapse toggle + browser-like back / forward navigation pair.
//
// The sidebar toggle is a bare icon button (no background). The [<] [>]
// history pair uses the same circular elevated style as the Discover
// carousel page navigators. Used inline beside the Discover tabs and in
// place of the per-page Back button.

import { Theme } from "../foundation/semantic-colors.slint";
import { NavState, ShellState } from "../state.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";

// Bare icon button — no background, brightest icon tint. Used for the
// sidebar collapse toggle.
component PlainNavBtn inherits Rectangle {
    in property <image> icon;
    callback clicked();

    width: 32px;
    height: 28px;

    QbzIcon {
        source: root.icon;
        width: 17px;
        height: 17px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: Theme.text-primary;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// Circular elevated icon button — same look as the Discover carousel
// page navigators (Carousel.slint NavButton).
component HistoryNavBtn inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 14px;
    opacity: root.enabled ? 1.0 : 0.4;
    background: ta.has-hover && root.enabled
        ? Theme.surface-hover
        : Theme.surface-elevated;

    QbzIcon {
        source: root.icon;
        width: 15px;
        height: 15px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: root.enabled ? Theme.text-primary : Theme.text-muted;
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component NavButtons inherits HorizontalLayout {
    spacing: 8px;

    // Sidebar collapse toggle — bare icon, no pill.
    VerticalLayout {
        alignment: center;
        PlainNavBtn {
            icon: @image-url("../assets/icons/panel-left.svg");
            clicked => {
                ShellState.sidebar-collapsed = !ShellState.sidebar-collapsed;
            }
        }
    }

    // Back / forward history pair — circular carousel-navigator style.
    HorizontalLayout {
        spacing: 4px;
        VerticalLayout {
            alignment: center;
            HistoryNavBtn {
                icon: @image-url("../assets/icons/chevron-left.svg");
                enabled: NavState.can-back;
                clicked => {
                    NavState.request-back();
                }
            }
        }
        VerticalLayout {
            alignment: center;
            HistoryNavBtn {
                icon: @image-url("../assets/icons/chevron-right.svg");
                enabled: NavState.can-forward;
                clicked => {
                    NavState.request-forward();
                }
            }
        }
    }
}
