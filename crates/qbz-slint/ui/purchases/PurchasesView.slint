// PurchasesView — the My-Purchases library surface (source-of-truth §2.1).
//
// 1:1 port of `PurchasesView.svelte`: header + region notice + sticky nav
// (Albums/Tracks tabs + collapsible search) + per-tab toolbar
// (group/sort/filter/grid-list) + content (grid / list / track rows, with
// group headers + empty/loading/error states) + the anchored format-picker
// popup. All filter / sort / group math runs in Rust (crate::purchases); this
// file is the chrome and binds `PurchasesState` / fires `PurchasesActions`.
//
// Self-contained album cards / list rows / track rows: the Tauri view uses
// bespoke markup for these (unavailable overlays, the BARE-quality track-row
// column §A.6, the purchase-date column, the 4-state download control), so
// reproducing them here is the faithful 1:1 rather than threading several
// Purchases-only flags through the shared AlbumCard / AlbumListRow / TrackRow.
// Genuinely-shared chrome (SegmentedTabBar tabs, ExpandableSearch, QbzSelect,
// QbzCheckbox) IS reused.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { Radius } from "../foundation/radius.slint";
import { QbzIcon } from "../primitives/QbzIcon.slint";
import { QbzCheckbox } from "../primitives/QbzCheckbox.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import {
    PurchasesState,
    PurchasesActions,
    PurchaseAlbumItem,
    PurchaseTrackItem,
    PurchaseAlbumGroup,
    PurchaseTrackGroup,
    PurchaseFormatItem,
} from "../state.slint";

// ── A toolbar dropdown button (group / sort) — the favorites toolbar look ──
// (6px radius, 30px tall, no outline). The caller owns the open/close menu.
component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;   // .selected (filter funnel active)
    callback clicked();

    height: 30px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 6px;
        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-primary;
            font-size: 12px;
            vertical-alignment: center;
        }
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: @image-url("../assets/icons/chevron-down.svg");
                width: 14px;
                height: 14px;
                tint: Theme.text-muted;
            }
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// One row in an open dropdown menu.
component MenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <string> arrow: "";   // "↑" / "↓" for the sort menu, else ""
    callback clicked();

    height: 32px;
    background: ta.has-hover ? Theme.surface-hover : transparent;
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Text {
            text: root.label;
            color: root.selected ? Theme.accent : Theme.text-secondary;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        if root.arrow != "": Text {
            text: root.arrow;
            color: Theme.accent;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Funnel button (icon-only) with the optional active-count badge.
component FilterButton inherits Rectangle {
    in property <bool> active: false;
    in property <int> count: 0;
    callback clicked();

    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;

    QbzIcon {
        source: @image-url("../assets/icons/list-filter.svg");
        width: 16px;
        height: 16px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: root.active ? Theme.accent : Theme.text-muted;
    }
    // Active-count badge — a small accent dot with the number.
    if root.count > 0: Rectangle {
        x: parent.width - self.width - 1px;
        y: 1px;
        width: 14px;
        height: 14px;
        border-radius: 7px;
        background: Theme.accent;
        Text {
            text: root.count;
            color: Theme.accent-text;
            font-size: 9px;
            font-weight: Typography.semibold;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Grid/List toggle button (icon-only). Shows List when in grid, LayoutGrid
// when in list (the icon points to the OTHER mode, like Tauri).
component ViewToggleButton inherits Rectangle {
    in property <string> view-mode: "grid";
    callback clicked();

    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: ta.has-hover ? Theme.surface-hover : Theme.surface-elevated;
    QbzIcon {
        source: root.view-mode == "grid"
            ? @image-url("../assets/icons/list.svg")
            : @image-url("../assets/icons/layout-grid.svg");
        width: 16px;
        height: 16px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        tint: ta.has-hover ? Theme.text-primary : Theme.text-muted;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// One Quality radio row in the filter panel.
component QualityRadio inherits Rectangle {
    in property <string> label;
    in property <string> hint: "";
    in property <bool> selected: false;
    callback clicked();

    height: 26px;
    HorizontalLayout {
        spacing: 8px;
        // Radio circle.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 8px;
                border-width: root.selected ? 0px : 1.5px;
                border-color: Theme.text-muted;
                background: root.selected ? Theme.accent : transparent;
                if root.selected: Rectangle {
                    width: 6px;
                    height: 6px;
                    border-radius: 3px;
                    background: Theme.accent-text;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: Typography.body;
            vertical-alignment: center;
        }
        if root.hint != "": Text {
            text: root.hint;
            color: Theme.text-muted;
            font-size: Typography.legal;
            vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// ── Grid album card (card-lite: cover / title / artist / quality; NO play
// overlay, §RESOLVED DECISION 3) with the unavailable dim + overlay. ──

// ── Grid album card (card-lite: cover / title / artist / quality; NO play
// overlay, §RESOLVED DECISION 3) with the unavailable dim + overlay. ──
component PurchaseGridCard inherits Rectangle {
    in property <PurchaseAlbumItem> album;
    callback clicked();

    // Unavailable: opacity .45 / grayscale (.55 on hover). Slint has no
    // grayscale filter, so we approximate the disabled look with opacity only
    // (the explicit overlay carries the "no longer available" meaning).
    property <bool> avail: root.album.downloadable;
    opacity: root.avail ? 1.0 : (card-ta.has-hover ? 0.55 : 0.45);

    VerticalLayout {
        spacing: 8px;
        // Cover (1:1).
        Rectangle {
            height: self.width;
            border-radius: Radius.sm;
            clip: true;
            background: Theme.surface-elevated;
            if root.album.artwork.width > 0: Image {
                source: root.album.artwork;
                width: 100%;
                height: 100%;
                image-fit: cover;
            }
            if root.album.artwork.width == 0: QbzIcon {
                source: @image-url("../assets/icons/disc-3.svg");
                width: 36px;
                height: 36px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                tint: Theme.text-muted;
            }
            // Unavailable overlay (top of the card, 1:1 aspect).
            if !root.avail: Rectangle {
                width: 100%;
                height: 100%;
                background: Theme.alpha-60;
                Text {
                    text: @tr("Unavailable");
                    color: Theme.text-primary;
                    font-size: Typography.legal;
                    font-weight: Typography.semibold;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
        Text {
            text: root.album.title;
            color: Theme.text-primary;
            font-size: Typography.body;
            font-weight: Typography.medium;
            overflow: elide;
        }
        Text {
            text: root.album.artist;
            color: Theme.text-muted;
            font-size: Typography.legal;
            overflow: elide;
        }
        if root.album.quality-label != "": Text {
            text: root.album.quality-label;
            color: Theme.text-secondary;
            font-size: Typography.legal;
            overflow: elide;
        }
    }
    card-ta := TouchArea {
        mouse-cursor: root.avail ? pointer : default;
        clicked => {
            if (root.avail) { root.clicked(); }
        }
    }
}

// ── Album list row (48×48 art, title/artist, quality, purchase-date). ──

// ── Album list row (48×48 art, title/artist, quality, purchase-date). ──
component PurchaseListRow inherits Rectangle {
    in property <PurchaseAlbumItem> album;
    callback clicked();

    property <bool> avail: root.album.downloadable;
    height: 60px;
    border-radius: Radius.sm;
    background: (row-ta.has-hover && root.avail) ? Theme.surface-hover : transparent;
    opacity: root.avail ? 1.0 : 0.5;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 12px;
        spacing: 12px;
        // 48×48 art.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 48px;
                height: 48px;
                border-radius: Radius.sm;
                clip: true;
                background: Theme.surface-elevated;
                if root.album.artwork.width > 0: Image {
                    source: root.album.artwork;
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                }
                if root.album.artwork.width == 0: QbzIcon {
                    source: @image-url("../assets/icons/disc-3.svg");
                    width: 20px;
                    height: 20px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: Theme.text-muted;
                }
            }
        }
        // Title + artist stacked.
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.album.title;
                color: Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                overflow: elide;
            }
            Text {
                text: root.album.artist;
                color: Theme.text-muted;
                font-size: Typography.legal;
                overflow: elide;
            }
        }
        // Quality column.
        VerticalLayout {
            alignment: center;
            width: 110px;
            Text {
                text: root.album.quality-list;
                color: Theme.text-secondary;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }
        // Purchase-date column.
        VerticalLayout {
            alignment: center;
            width: 110px;
            Text {
                text: root.album.purchase-date;
                color: Theme.text-muted;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }
        // Unavailable label (extra column).
        if !root.avail: VerticalLayout {
            alignment: center;
            Text {
                text: @tr("Unavailable");
                color: Theme.text-muted;
                font-size: Typography.legal;
            }
        }
    }
    row-ta := TouchArea {
        mouse-cursor: root.avail ? pointer : default;
        clicked => {
            if (root.avail) { root.clicked(); }
        }
    }
}

// ── Track row (40×40 art, title, artist link · album, quality, duration,
// date) + the 4-state download control. ──

// ── Track row (40×40 art, title, artist link · album, quality, duration,
// date) + the 4-state download control. ──
component PurchaseTrackRow inherits Rectangle {
    in property <PurchaseTrackItem> track;
    in property <bool> active: false;
    in property <bool> playing: false;
    callback play();
    callback open-artist();
    // Download requested — pass the row's anchor (bottom-right of the button)
    // so the controller can position the format picker.
    callback download(length /* anchor-x */, length /* anchor-y */);

    property <bool> is-downloaded: root.track.downloaded || root.track.dl-status == "complete";
    height: 56px;
    border-radius: Radius.sm;
    background: root.active ? Theme.alpha-10
        : (row-ta.has-hover && root.track.streamable ? Theme.surface-hover : transparent);
    // Downloaded rows dim to .75.
    opacity: root.is-downloaded ? 0.75 : 1.0;

    // Row click → play (only when streamable). Declared first so the per-cell
    // download / artist TouchAreas (children, hit-tested later) still win.
    row-ta := TouchArea {
        enabled: root.track.streamable;
        mouse-cursor: root.track.streamable ? pointer : default;
        clicked => { root.play(); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 12px;
        spacing: 12px;
        // 40×40 artwork.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                border-radius: Radius.sm;
                clip: true;
                background: Theme.surface-elevated;
                if root.track.artwork.width > 0: Image {
                    source: root.track.artwork;
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                }
                if root.track.artwork.width == 0: QbzIcon {
                    source: @image-url("../assets/icons/music.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: Theme.text-muted;
                }
            }
        }
        // Title + meta line.
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.track.title;
                color: root.active ? Theme.accent : Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.medium;
                overflow: elide;
            }
            HorizontalLayout {
                spacing: 5px;
                // Artist link.
                Text {
                    text: root.track.artist;
                    color: artist-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                    font-size: Typography.legal;
                    vertical-alignment: center;
                    artist-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-artist(); }
                    }
                }
                if root.track.album-title != "": Text {
                    text: "·";
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    vertical-alignment: center;
                }
                if root.track.album-title != "": Text {
                    text: root.track.album-title;
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
        // Quality column — BARE "{bit}/{rate}" (§A.6).
        if root.track.quality != "": VerticalLayout {
            alignment: center;
            width: 64px;
            Text {
                text: root.track.quality;
                color: Theme.text-secondary;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }
        // Duration column.
        VerticalLayout {
            alignment: center;
            width: 44px;
            Text {
                text: root.track.duration;
                color: Theme.text-muted;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }
        // Purchase-date column.
        VerticalLayout {
            alignment: center;
            width: 100px;
            Text {
                text: root.track.purchase-date;
                color: Theme.text-muted;
                font-size: Typography.legal;
                horizontal-alignment: right;
            }
        }
        // Download control (4 states).
        VerticalLayout {
            alignment: center;
            dl-slot := Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 6px;
                background: dl-ta.has-hover ? Theme.surface-elevated : transparent;
                // downloading → spinner, no button.
                if root.track.dl-status == "downloading": LoadingSpinner {
                    size: 14px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
                // complete / server-downloaded → green check (download on hover).
                if root.track.dl-status != "downloading" && root.is-downloaded: QbzIcon {
                    source: dl-ta.has-hover
                        ? @image-url("../assets/icons/download.svg")
                        : @image-url("../assets/icons/check.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: dl-ta.has-hover ? Theme.text-primary : Theme.success;
                }
                // failed → red download (retry).
                if root.track.dl-status == "failed" && !root.is-downloaded: QbzIcon {
                    source: @image-url("../assets/icons/download.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: Theme.danger;
                }
                // idle → plain download.
                if root.track.dl-status != "downloading"
                    && root.track.dl-status != "failed"
                    && !root.is-downloaded: QbzIcon {
                    source: @image-url("../assets/icons/download.svg");
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    tint: dl-ta.has-hover ? Theme.text-primary : Theme.text-muted;
                }
                dl-ta := TouchArea {
                    // Always shows the control regardless of streamable (§B.4).
                    enabled: root.track.dl-status != "downloading";
                    mouse-cursor: pointer;
                    clicked => {
                        // Anchor: bottom-right of the button in window coords.
                        root.download(
                            dl-slot.absolute-position.x + dl-slot.width,
                            dl-slot.absolute-position.y + dl-slot.height);
                    }
                }
            }
        }
    }
}

// One Albums/Tracks tab button with a count badge + active accent underline.
component TabButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <int> count;
    in property <bool> active;
    callback clicked();

    height: 36px;
    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        spacing: 7px;
        VerticalLayout {
            alignment: center;
            QbzIcon {
                source: root.icon;
                width: 16px;
                height: 16px;
                tint: root.active ? Theme.text-primary : Theme.text-muted;
            }
        }
        Text {
            text: root.label;
            color: root.active ? Theme.text-primary : Theme.text-muted;
            font-size: Typography.body;
            font-weight: Typography.medium;
            vertical-alignment: center;
        }
        if root.count > 0: VerticalLayout {
            alignment: center;
            Text {
                text: root.count;
                color: root.active ? Theme.text-secondary : Theme.text-muted;
                font-size: Typography.legal;
                vertical-alignment: center;
            }
        }
    }
    // Active accent underline (non-pill cue).
    if root.active: Rectangle {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        height: 2px;
        border-radius: 1px;
        background: Theme.accent;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// Collapsible search — magnifier toggle that opens a right-anchored input
// with leading magnifier + trailing clear/close. Mirrors §2.1.9 search.

// Collapsible search — magnifier toggle that opens a right-anchored input
// with leading magnifier + trailing clear/close. Mirrors §2.1.9 search.
component SearchBox inherits Rectangle {
    width: PurchasesState.search-query != "" || expanded ? 220px : 34px;
    height: 34px;
    property <bool> expanded: false;
    // Bumped on expand so the input (declared inside the `if`) grabs focus a
    // tick later — the input watches this and focuses on change.
    property <int> focus-tick: 0;

    // Collapsed magnifier toggle.
    Rectangle {
        opacity: root.expanded || PurchasesState.search-query != "" ? 0.0 : 1.0;
        width: 34px;
        height: 34px;
        border-radius: 6px;
        background: open-ta.has-hover ? Theme.surface-hover : transparent;
        QbzIcon {
            source: @image-url("../assets/icons/search.svg");
            width: 16px;
            height: 16px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            tint: open-ta.has-hover ? Theme.text-primary : Theme.text-muted;
        }
        open-ta := TouchArea {
            enabled: !root.expanded && PurchasesState.search-query == "";
            mouse-cursor: pointer;
            clicked => {
                root.expanded = true;
                root.focus-tick += 1;
            }
        }
    }

    // Expanded input.
    if root.expanded || PurchasesState.search-query != "": Rectangle {
        width: 100%;
        height: 34px;
        background: Theme.surface-card;
        border-radius: 6px;
        border-width: 1px;
        border-color: input.has-focus ? Theme.focus-ring : Theme.border-subtle;
        // Focus the field a tick after expand (the open-ta bumps `focus-tick`).
        focus-timer := Timer {
            interval: 30ms;
            running: root.focus-tick > 0 && !input.has-focus && root.expanded;
            triggered => {
                input.focus();
                self.running = false;
            }
        }
        HorizontalLayout {
            padding-left: 11px;
            padding-right: 5px;
            spacing: 8px;
            VerticalLayout {
                alignment: center;
                QbzIcon {
                    source: @image-url("../assets/icons/search.svg");
                    width: 14px;
                    height: 14px;
                    tint: Theme.text-muted;
                }
            }
            Rectangle {
                horizontal-stretch: 1;
                clip: true;
                input := TextInput {
                    width: 100%;
                    height: 100%;
                    color: Theme.text-primary;
                    font-size: Typography.body;
                    vertical-alignment: center;
                    single-line: true;
                    text <=> PurchasesState.search-query;
                    edited => {
                        PurchasesActions.search(self.text);
                    }
                }
                Text {
                    visible: input.text == "";
                    width: 100%;
                    height: 100%;
                    text: @tr("Search purchases…");
                    color: Theme.text-muted;
                    font-size: Typography.body;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            // Trailing X — clears when non-empty, else collapses.
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: 4px;
                    background: clear-ta.has-hover ? Theme.surface-elevated : transparent;
                    QbzIcon {
                        source: @image-url("../assets/icons/x.svg");
                        width: 12px;
                        height: 12px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        tint: Theme.text-muted;
                    }
                    clear-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if (PurchasesState.search-query != "") {
                                PurchasesActions.clear-search();
                            }
                            root.expanded = false;
                        }
                    }
                }
            }
        }
    }
}

// Albums toolbar — group / sort / filter / grid-list, with the open menus.

// One sort menu row — flips direction on re-click via select-album-sort; shows
// the active ↑/↓ arrow.
component SortRow inherits MenuRow {
    in property <string> sort-key;
    selected: PurchasesState.album-sort-by == root.sort-key;
    arrow: PurchasesState.album-sort-by == root.sort-key
        ? (PurchasesState.album-sort-direction == "asc" ? "↑" : "↓")
        : "";
    clicked => { PurchasesActions.select-album-sort(root.sort-key); }
}

// Tracks toolbar — group dropdown + filter (NO availability, no sort/grid).

// Shared filter panel (albums variant adds the Availability section).
component FilterPanel inherits Rectangle {
    in property <bool> show-availability: true;
    // ADR-009: lift the anchored filter panel above sibling toolbar controls so
    // it never renders behind them regardless of declaration order.
    z: 3000;
    width: 280px;
    height: panel.preferred-height;
    background: Theme.surface-card;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.border-muted;
    drop-shadow-blur: 20px;
    drop-shadow-color: Theme.card-shadow;
    drop-shadow-offset-y: 5px;

    panel := VerticalLayout {
        padding: 14px;
        spacing: 10px;
        // Header + clear-all.
        HorizontalLayout {
            Text {
                text: @tr("Filters");
                color: Theme.text-primary;
                font-size: Typography.body;
                font-weight: Typography.semibold;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            if PurchasesState.has-active-filters: Rectangle {
                width: clear-txt.preferred-width;
                height: 20px;
                clear-txt := Text {
                    text: @tr("Clear all");
                    color: Theme.accent;
                    font-size: Typography.legal;
                    vertical-alignment: center;
                }
                clearall-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { PurchasesActions.clear-all-filters(); }
                }
            }
        }
        // Availability (albums only).
        if root.show-availability: VerticalLayout {
            spacing: 6px;
            Text {
                text: @tr("Availability");
                color: Theme.text-muted;
                font-size: Typography.legal;
                font-weight: Typography.semibold;
            }
            HorizontalLayout {
                spacing: 8px;
                QbzCheckbox {
                    checked: PurchasesState.filter-hide-unavailable;
                    toggled => {
                        PurchasesActions.set-filter-hide-unavailable(self.checked);
                    }
                }
                Text {
                    text: @tr("Hide unavailable");
                    color: Theme.text-primary;
                    font-size: Typography.body;
                    vertical-alignment: center;
                }
            }
        }
        // Quality radios.
        VerticalLayout {
            spacing: 4px;
            Text {
                text: @tr("Quality");
                color: Theme.text-muted;
                font-size: Typography.legal;
                font-weight: Typography.semibold;
            }
            QualityRadio {
                label: @tr("All");
                selected: PurchasesState.filter-quality == "all";
                clicked => { PurchasesActions.set-filter-quality("all"); }
            }
            QualityRadio {
                label: @tr("Hi-Res");
                hint: "24bit+";
                selected: PurchasesState.filter-quality == "hires";
                clicked => { PurchasesActions.set-filter-quality("hires"); }
            }
            QualityRadio {
                label: @tr("CD Quality");
                hint: "16/44.1";
                selected: PurchasesState.filter-quality == "cd";
                clicked => { PurchasesActions.set-filter-quality("cd"); }
            }
            QualityRadio {
                label: @tr("MP3");
                hint: "MP3";
                selected: PurchasesState.filter-quality == "lossy";
                clicked => { PurchasesActions.set-filter-quality("lossy"); }
            }
        }
        // Downloads.
        VerticalLayout {
            spacing: 6px;
            Text {
                text: @tr("Downloads");
                color: Theme.text-muted;
                font-size: Typography.legal;
                font-weight: Typography.semibold;
            }
            HorizontalLayout {
                spacing: 8px;
                QbzCheckbox {
                    checked: PurchasesState.filter-hide-downloaded;
                    toggled => {
                        PurchasesActions.set-filter-hide-downloaded(self.checked);
                    }
                }
                Text {
                    text: @tr("Hide downloaded");
                    color: Theme.text-primary;
                    font-size: Typography.body;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// Empty / error block — centered icon + message.

// Albums toolbar — group / sort / filter / grid-list, with the open menus.
component AlbumsToolbar inherits Rectangle {
    height: bar.preferred-height;
    bar := HorizontalLayout {
        spacing: 8px;
        Rectangle { horizontal-stretch: 1; }
        // Group dropdown.
        Rectangle {
            width: group-btn.preferred-width;
            height: 30px;
            group-btn := ToolbarButton {
                label: PurchasesState.album-grouping-enabled
                    ? (PurchasesState.album-group-mode == "artist"
                        ? @tr("Group: Artist") : @tr("Group: A–Z"))
                    : @tr("Group: Off");
                clicked => {
                    PurchasesActions.set-open-menu(
                        PurchasesState.open-menu == "albumGroup" ? "" : "albumGroup");
                }
            }
            if PurchasesState.open-menu == "albumGroup": Rectangle {
                x: 0;
                y: parent.height + 4px;
                width: 180px;
                height: gmenu.preferred-height;
                background: Theme.surface-card;
                border-radius: Radius.sm;
                border-width: 1px;
                border-color: Theme.border-muted;
                drop-shadow-blur: 20px;
                drop-shadow-color: Theme.card-shadow;
                drop-shadow-offset-y: 5px;
                gmenu := VerticalLayout {
                    padding-top: 5px;
                    padding-bottom: 5px;
                    MenuRow {
                        label: @tr("Off");
                        selected: !PurchasesState.album-grouping-enabled;
                        clicked => { PurchasesActions.set-album-group("off"); }
                    }
                    MenuRow {
                        label: @tr("A–Z");
                        selected: PurchasesState.album-grouping-enabled && PurchasesState.album-group-mode == "alpha";
                        clicked => { PurchasesActions.set-album-group("alpha"); }
                    }
                    MenuRow {
                        label: @tr("Artist");
                        selected: PurchasesState.album-grouping-enabled && PurchasesState.album-group-mode == "artist";
                        clicked => { PurchasesActions.set-album-group("artist"); }
                    }
                }
            }
        }
        // Sort dropdown.
        Rectangle {
            width: sort-btn.preferred-width;
            height: 30px;
            sort-btn := ToolbarButton {
                label: PurchasesState.album-sort-by == "date" ? @tr("Sort: Date")
                    : (PurchasesState.album-sort-by == "artist" ? @tr("Sort: Artist")
                    : (PurchasesState.album-sort-by == "album" ? @tr("Sort: Album")
                    : @tr("Sort: Quality")));
                clicked => {
                    PurchasesActions.set-open-menu(
                        PurchasesState.open-menu == "albumSort" ? "" : "albumSort");
                }
            }
            if PurchasesState.open-menu == "albumSort": Rectangle {
                x: 0;
                y: parent.height + 4px;
                width: 180px;
                height: smenu.preferred-height;
                background: Theme.surface-card;
                border-radius: Radius.sm;
                border-width: 1px;
                border-color: Theme.border-muted;
                drop-shadow-blur: 20px;
                drop-shadow-color: Theme.card-shadow;
                drop-shadow-offset-y: 5px;
                smenu := VerticalLayout {
                    padding-top: 5px;
                    padding-bottom: 5px;
                    SortRow { sort-key: "date"; label: @tr("Date"); }
                    SortRow { sort-key: "artist"; label: @tr("Artist"); }
                    SortRow { sort-key: "album"; label: @tr("Album"); }
                    SortRow { sort-key: "quality"; label: @tr("Quality"); }
                }
            }
        }
        // Filter button.
        Rectangle {
            width: 30px;
            height: 30px;
            FilterButton {
                active: PurchasesState.has-active-filters;
                count: PurchasesState.active-filter-count;
                clicked => {
                    PurchasesActions.set-open-menu(
                        PurchasesState.open-menu == "filter" ? "" : "filter");
                }
            }
            if PurchasesState.open-menu == "filter": FilterPanel {
                x: parent.width - self.width;
                y: parent.height + 4px;
                show-availability: true;
            }
        }
        // Grid/List toggle.
        ViewToggleButton {
            view-mode: PurchasesState.album-view-mode;
            clicked => {
                PurchasesActions.set-album-view-mode(
                    PurchasesState.album-view-mode == "grid" ? "list" : "grid");
            }
        }
    }
}

// One sort menu row — flips direction on re-click via select-album-sort; shows
// the active ↑/↓ arrow.

// Tracks toolbar — group dropdown + filter (NO availability, no sort/grid).
component TracksToolbar inherits Rectangle {
    height: bar.preferred-height;
    bar := HorizontalLayout {
        spacing: 8px;
        Rectangle { horizontal-stretch: 1; }
        // Track group dropdown.
        Rectangle {
            width: tgroup-btn.preferred-width;
            height: 30px;
            tgroup-btn := ToolbarButton {
                label: PurchasesState.track-grouping-enabled
                    ? (PurchasesState.track-group-mode == "album" ? @tr("Group: Album")
                        : (PurchasesState.track-group-mode == "name" ? @tr("Group: Name")
                        : @tr("Group: Artist")))
                    : @tr("Group: Off");
                clicked => {
                    PurchasesActions.set-open-menu(
                        PurchasesState.open-menu == "trackGroup" ? "" : "trackGroup");
                }
            }
            if PurchasesState.open-menu == "trackGroup": Rectangle {
                x: 0;
                y: parent.height + 4px;
                width: 180px;
                height: tgmenu.preferred-height;
                background: Theme.surface-card;
                border-radius: Radius.sm;
                border-width: 1px;
                border-color: Theme.border-muted;
                drop-shadow-blur: 20px;
                drop-shadow-color: Theme.card-shadow;
                drop-shadow-offset-y: 5px;
                tgmenu := VerticalLayout {
                    padding-top: 5px;
                    padding-bottom: 5px;
                    MenuRow {
                        label: @tr("Off");
                        selected: !PurchasesState.track-grouping-enabled;
                        clicked => { PurchasesActions.set-track-group("off"); }
                    }
                    MenuRow {
                        label: @tr("Album");
                        selected: PurchasesState.track-grouping-enabled && PurchasesState.track-group-mode == "album";
                        clicked => { PurchasesActions.set-track-group("album"); }
                    }
                    MenuRow {
                        label: @tr("Artist");
                        selected: PurchasesState.track-grouping-enabled && PurchasesState.track-group-mode == "artist";
                        clicked => { PurchasesActions.set-track-group("artist"); }
                    }
                    MenuRow {
                        label: @tr("Name");
                        selected: PurchasesState.track-grouping-enabled && PurchasesState.track-group-mode == "name";
                        clicked => { PurchasesActions.set-track-group("name"); }
                    }
                }
            }
        }
        // Filter button (no availability section).
        Rectangle {
            width: 30px;
            height: 30px;
            FilterButton {
                active: PurchasesState.has-active-filters;
                count: PurchasesState.active-filter-count;
                clicked => {
                    PurchasesActions.set-open-menu(
                        PurchasesState.open-menu == "filter" ? "" : "filter");
                }
            }
            if PurchasesState.open-menu == "filter": FilterPanel {
                x: parent.width - self.width;
                y: parent.height + 4px;
                show-availability: false;
            }
        }
    }
}

// Shared filter panel (albums variant adds the Availability section).

// Empty / error block — centered icon + message.
component EmptyBlock inherits VerticalLayout {
    in property <image> icon;
    in property <string> text;
    alignment: center;
    spacing: 12px;
    Rectangle { height: 60px; }
    HorizontalLayout {
        alignment: center;
        QbzIcon {
            source: root.icon;
            width: 48px;
            height: 48px;
            tint: Theme.text-muted;
        }
    }
    HorizontalLayout {
        alignment: center;
        Text {
            text: root.text;
            color: Theme.text-muted;
            font-size: Typography.body;
        }
    }
}

// The albums-grid / albums-list / tracks-list content with group headers.

// An album grid OR list for one (flat or per-group) collection.
component AlbumsCollection inherits Rectangle {
    in property <[PurchaseAlbumItem]> albums;
    in property <string> view-mode: "grid";
    callback open-album-detail(string);

    // Grid column math (auto-fill minmax 162px, gap 16).
    property <length> card-width: 162px;
    property <length> card-gap: 16px;
    property <length> card-height: 232px;
    property <int> columns: Math.max(1,
        Math.floor((self.width + root.card-gap) / (root.card-width + root.card-gap)));
    property <int> grid-rows: Math.ceil(root.albums.length / root.columns);
    // List row geometry (60px row + 4px gap) — computed so the root height is
    // known without referencing a child inside an `if` (which Slint scopes out).
    property <length> list-row-height: 60px;
    property <length> list-gap: 4px;

    height: root.view-mode == "grid"
        ? (root.grid-rows > 0
            ? root.grid-rows * root.card-height + Math.max(0, root.grid-rows - 1) * root.card-gap
            : 0px)
        : (root.albums.length > 0
            ? root.albums.length * root.list-row-height
                + Math.max(0, root.albums.length - 1) * root.list-gap
            : 0px);

    // Grid.
    if root.view-mode == "grid": Rectangle {
        for album[i] in root.albums: PurchaseGridCard {
            x: Math.mod(i, root.columns) * (root.card-width + root.card-gap);
            y: Math.floor(i / root.columns) * (root.card-height + root.card-gap);
            width: root.card-width;
            height: root.card-height;
            album: album;
            clicked => { root.open-album-detail(album.id); }
        }
    }

    // List.
    if root.view-mode == "list": VerticalLayout {
        spacing: root.list-gap;
        for album[i] in root.albums: PurchaseListRow {
            album: album;
            height: root.list-row-height;
            clicked => { root.open-album-detail(album.id); }
        }
    }
}

// A track list for one (flat or per-group) collection.
component TracksCollection inherits VerticalLayout {
    in property <[PurchaseTrackItem]> tracks;
    callback play-track(string);
    callback open-artist(string);
    spacing: 2px;
    for track[i] in root.tracks: PurchaseTrackRow {
        track: track;
        active: PurchasesState.active-track-id == track.id;
        playing: PurchasesState.active-track-id == track.id && PurchasesState.playback-active;
        play => { root.play-track(track.id); }
        open-artist => {
            if (track.artist-id != "") { root.open-artist(track.artist-id); }
        }
        download(ax, ay) => {
            PurchasesActions.download-track(track.id, ax, ay);
        }
    }
}

// The albums-grid / albums-list / tracks-list content with group headers.
component ContentArea inherits VerticalLayout {
    callback open-album-detail(string);
    callback open-artist(string);
    callback play-track(string);
    spacing: 16px;

    // ── Albums tab ──
    if PurchasesState.active-tab == "albums": VerticalLayout {
        spacing: 16px;
        // Empty.
        if PurchasesState.albums.length == 0 && PurchasesState.albums-grouped.length == 0: EmptyBlock {
            icon: @image-url("../assets/icons/shopping-bag.svg");
            text: @tr("No purchases yet");
        }
        // Flat (not grouped).
        if !PurchasesState.album-grouping-enabled && PurchasesState.albums.length > 0: AlbumsCollection {
            albums: PurchasesState.albums;
            view-mode: PurchasesState.album-view-mode;
            open-album-detail(id) => { root.open-album-detail(id); }
        }
        // Grouped.
        if PurchasesState.album-grouping-enabled: VerticalLayout {
            spacing: 16px;
            for group[g] in PurchasesState.albums-grouped: VerticalLayout {
                spacing: 12px;
                if group.title != "": Text {
                    text: group.title;
                    color: Theme.text-primary;
                    font-size: Typography.heading;
                    font-weight: Typography.semibold;
                }
                AlbumsCollection {
                    albums: group.albums;
                    view-mode: PurchasesState.album-view-mode;
                    open-album-detail(id) => { root.open-album-detail(id); }
                }
            }
        }
    }

    // ── Tracks tab ──
    if PurchasesState.active-tab == "tracks": VerticalLayout {
        spacing: 16px;
        if PurchasesState.tracks.length == 0 && PurchasesState.tracks-grouped.length == 0: EmptyBlock {
            icon: @image-url("../assets/icons/music.svg");
            text: @tr("No purchased tracks yet");
        }
        if !PurchasesState.track-grouping-enabled && PurchasesState.tracks.length > 0: TracksCollection {
            tracks: PurchasesState.tracks;
            play-track(id) => { root.play-track(id); }
            open-artist(id) => { root.open-artist(id); }
        }
        if PurchasesState.track-grouping-enabled: VerticalLayout {
            spacing: 16px;
            for group[g] in PurchasesState.tracks-grouped: VerticalLayout {
                spacing: 8px;
                if group.title != "": Text {
                    text: group.title;
                    color: Theme.text-primary;
                    font-size: Typography.heading;
                    font-weight: Typography.semibold;
                }
                TracksCollection {
                    tracks: group.tracks;
                    play-track(id) => { root.play-track(id); }
                    open-artist(id) => { root.open-artist(id); }
                }
            }
        }
    }
}

// An album grid OR list for one (flat or per-group) collection.

export component PurchasesView inherits Rectangle {
    callback open-album(string);
    callback open-artist(string);
    callback media-action(string, string, string);

    background: Theme.surface-main;

    // Outside-press dismissal for any open menu (§2.1.16): a full-area
    // TouchArea behind the content that closes `open-menu` on a press that
    // misses the toolbar controls + the format picker. Declared FIRST so the
    // controls (declared later) are hit-tested first and swallow their own
    // clicks; this only catches presses that fall through.
    if PurchasesState.open-menu != "" || PurchasesState.picker-track-id != "": TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            PurchasesActions.set-open-menu("");
            PurchasesActions.close-format-picker();
        }
    }

    Flickable {
        viewport-width: self.width;
        viewport-height: content.preferred-height;

        content := VerticalLayout {
            padding: 24px;
            spacing: 16px;

            // 1. Header — gradient icon box + title.
            HorizontalLayout {
                spacing: 16px;
                Rectangle {
                    width: 94px;
                    height: 94px;
                    border-radius: 12px;
                    background: @linear-gradient(135deg, Theme.accent 0%, #6b8aff 100%);
                    QbzIcon {
                        source: @image-url("../assets/icons/shopping-bag.svg");
                        width: 32px;
                        height: 32px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        tint: white;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: @tr("My Purchases");
                        color: Theme.text-primary;
                        font-size: Typography.title;
                        font-weight: Typography.bold;
                    }
                }
            }

            // 2. Region-notice banner (dismissible).
            if PurchasesState.show-region-notice: Rectangle {
                border-radius: 8px;
                background: Theme.accent.with-alpha(0.10);
                border-width: 1px;
                border-color: Theme.accent.with-alpha(0.30);
                height: notice-row.preferred-height;
                notice-row := HorizontalLayout {
                    padding: 12px;
                    spacing: 10px;
                    VerticalLayout {
                        alignment: start;
                        QbzIcon {
                            source: @image-url("../assets/icons/info.svg");
                            width: 18px;
                            height: 18px;
                            tint: Theme.accent;
                        }
                    }
                    Text {
                        text: @tr("Purchases are downloaded as DRM-free files. Availability depends on your Qobuz region.");
                        color: Theme.text-secondary;
                        font-size: Typography.body;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                    Rectangle {
                        width: 24px;
                        height: 24px;
                        border-radius: 4px;
                        background: close-ta.has-hover ? Theme.surface-elevated : transparent;
                        QbzIcon {
                            source: @image-url("../assets/icons/x.svg");
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            tint: Theme.text-muted;
                        }
                        close-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { PurchasesActions.dismiss-region-notice(); }
                        }
                    }
                }
            }

            // 3. Sticky nav bar — tabs (left) + search (right).
            HorizontalLayout {
                spacing: 8px;
                // Albums tab.
                TabButton {
                    icon: @image-url("../assets/icons/disc-3.svg");
                    label: @tr("Albums");
                    count: PurchasesState.album-tab-count;
                    active: PurchasesState.active-tab == "albums";
                    clicked => { PurchasesActions.select-tab("albums"); }
                }
                // Tracks tab.
                TabButton {
                    icon: @image-url("../assets/icons/music.svg");
                    label: @tr("Tracks");
                    count: PurchasesState.track-tab-count;
                    active: PurchasesState.active-tab == "tracks";
                    clicked => { PurchasesActions.select-tab("tracks"); }
                }
                Rectangle { horizontal-stretch: 1; }
                // Search (collapsible).
                SearchBox { }
            }

            // 4. Toolbar — per active tab.
            if PurchasesState.active-tab == "albums": AlbumsToolbar { }
            if PurchasesState.active-tab == "tracks": TracksToolbar { }

            // 5. Content.
            if PurchasesState.loading: VerticalLayout {
                alignment: center;
                Rectangle { height: 80px; }
                HorizontalLayout {
                    alignment: center;
                    LoadingSpinner {
                        size: 32px;
                    }
                }
            }
            if !PurchasesState.loading && PurchasesState.load-error != "": EmptyBlock {
                icon: @image-url("../assets/icons/shopping-bag.svg");
                // The controller already maps i18n keys to their English text,
                // so the load-error is the final display string.
                text: PurchasesState.load-error;
            }
            if !PurchasesState.loading && PurchasesState.load-error == "": ContentArea {
                open-album-detail(id) => { root.open-album(id); }
                open-artist(id) => { root.open-artist(id); }
                play-track(id) => { root.media-action("track", id, "play"); }
            }
        }
    }

    // 6. Format-picker popup (anchored). Backdrop z3000 / popup z3001 (ADR-009).
    if PurchasesState.picker-track-id != "": Rectangle {
        // Backdrop.
        TouchArea {
            z: 3000;
            width: root.width;
            height: root.height;
            clicked => { PurchasesActions.close-format-picker(); }
        }
        // Anchored picker. `picker-anchor-x` is the button's RIGHT edge; pin the
        // picker's right edge there. `picker-anchor-y` is below the button.
        // The anchor is captured in WINDOW-absolute coords (from the button's
        // `absolute-position`), but this picker renders in PurchasesView-LOCAL
        // space (the view is mounted inside AppShell's sidebar+content layout,
        // so its origin is offset from the window). Subtract the view's own
        // `absolute-position` to convert the anchor back into local space —
        // otherwise the popup shifts right by ~sidebar-width and down by the
        // top chrome.
        //
        // VERIFICATION CAVEAT (Flickable double-count, untestable here — the
        // download flow can't be functionally exercised): the anchor is read
        // from `dl-slot.absolute-position`, and `dl-slot` lives in a row nested
        // INSIDE the Flickable above (line ~1329). Per the documented Slint
        // gotcha (memory `reference_slint_absolute_position_flickable`), an
        // element's `absolute-position` inside a Flickable/ListView can
        // DOUBLE-COUNT its own layout offset and does not subtract the scroll
        // viewport offset. The `- root.absolute-position` here cancels only the
        // window→view translation, NOT that double-count/scroll delta — so the
        // picker may sit at the wrong Y and drift further as the list scrolls.
        // If that manifests, compute the anchor as
        // `dl-slot.absolute-position - <flickable>.absolute-position` (scroll-
        // safe) at the call site (line ~600) rather than patching the math here.
        Rectangle {
            z: 3001;
            x: Math.max(8px, (PurchasesState.picker-anchor-x - root.absolute-position.x) - self.width);
            y: (PurchasesState.picker-anchor-y - root.absolute-position.y) + 4px;
            width: 240px;
            height: picker-col.preferred-height;
            background: Theme.surface-card;
            border-radius: Radius.sm;
            border-width: 1px;
            border-color: Theme.border-muted;
            drop-shadow-blur: 20px;
            drop-shadow-color: Theme.card-shadow;
            drop-shadow-offset-y: 5px;
            picker-col := VerticalLayout {
                padding: 6px;
                Text {
                    text: @tr("Select format");
                    color: Theme.text-muted;
                    font-size: Typography.legal;
                    font-weight: Typography.semibold;
                    // small header padding
                    height: 28px;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }
                for fmt[i] in PurchasesState.picker-formats: Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: fmt-ta.has-hover ? Theme.surface-hover : transparent;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 8px;
                        Text {
                            text: fmt.label;
                            color: Theme.text-primary;
                            font-size: Typography.body;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        if fmt.detail != "": Text {
                            text: fmt.detail;
                            color: Theme.text-muted;
                            font-size: Typography.legal;
                            vertical-alignment: center;
                        }
                    }
                    fmt-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            PurchasesActions.pick-format(PurchasesState.picker-track-id, fmt.id);
                        }
                    }
                }
            }
        }
    }
}
