// Player seek bar — elapsed time, a three-line track (total / cached /
// progress) with a hover thumb, and the remaining time. On hover the
// cursor shows a time bubble with a downward caret marking the position
// it would seek to.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";

export component SeekBar inherits HorizontalLayout {
    in property <float> progress: 0.0;   // 0..1 played
    in property <float> cache: 0.0;      // 0..1 buffered
    in property <float> seekable-max: 1.0; // furthest seekable fraction (stream lock)
    in property <string> elapsed: "0:00";
    in property <string> remaining: "0:00";
    in property <int> duration-secs: 0;
    // Whether to render the leading/trailing time labels. Default true so the
    // New/Classic bars are unchanged; the Small bar mounts the top full-width
    // seekbar with show-times:false (it carries its own time column instead).
    in property <bool> show-times: true;
    callback seek(float);                // 0..1

    spacing: root.show-times ? 12px : 0px;

    function clamp01(v: float) -> float {
        return Math.min(Math.max(v, 0.0), 1.0);
    }
    function fmt(secs: int) -> string {
        return "\{Math.floor(secs / 60)}:\{Math.mod(secs, 60) < 10 ? "0" : ""}\{Math.mod(secs, 60)}";
    }

    if root.show-times: VerticalLayout {
        alignment: center;
        Text {
            text: root.elapsed;
            width: 44px;
            horizontal-alignment: right;
            color: Theme.text-muted;
            font-size: 11px;
        }
    }

    VerticalLayout {
        alignment: center;
        horizontal-stretch: 1;

        track := Rectangle {
            height: 3px;
            border-radius: 2px;
            background: Theme.surface-elevated;

            // Buffered / cache line.
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width * root.clamp01(root.cache);
                height: parent.height;
                border-radius: 2px;
                background: Theme.text-muted;
                opacity: 0.35;
            }
            // Playback progress line.
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width * root.clamp01(root.progress);
                height: parent.height;
                border-radius: 2px;
                background: Theme.accent;
            }
            // Hover thumb. HC-only border delineates the disc against the
            // filled track. (No HC outline on the 3px rail itself: a 1px
            // border top+bottom would swallow the thin line — the thumb
            // border carries the redundant-encoding for the seek bar.)
            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: Theme.text-primary;
                border-width: Theme.is-high-contrast ? 1px : 0px;
                border-color: Theme.border-strong;
                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                x: parent.width * root.clamp01(root.progress) - self.width / 2;
                opacity: ta.has-hover ? 1.0 : 0.0;
                animate opacity { duration: 100ms; }
            }

            // Tall, easy-to-grab hit area over the thin line.
            ta := TouchArea {
                width: 100%;
                height: 18px;
                y: Math.round((parent.height - self.height) / 2 / 1px) * 1px;
                // No-drop cursor over the not-yet-downloaded region.
                mouse-cursor: (root.clamp01(self.mouse-x / self.width) > root.seekable-max)
                    ? MouseCursor.not-allowed
                    : MouseCursor.pointer;
                clicked => {
                    // Lock the seek target to what has downloaded while streaming.
                    root.seek(Math.min(root.clamp01(self.mouse-x / self.width), root.seekable-max));
                }
            }

            // Hover time tooltip with a downward caret.
            tip := Rectangle {
                property <int> at-secs:
                    Math.round(root.clamp01(ta.mouse-x / track.width) * root.duration-secs);
                x: Math.min(Math.max(ta.mouse-x - self.width / 2, 0px),
                    track.width - self.width);
                y: -self.height - 11px;
                width: bubble.preferred-width;
                height: 24px;
                opacity: ta.has-hover ? 1.0 : 0.0;
                animate opacity { duration: 80ms; }

                bubble := Rectangle {
                    background: Theme.surface-elevated;
                    border-radius: 4px;
                    drop-shadow-blur: 10px;
                    drop-shadow-color: #00000099;
                    HorizontalLayout {
                        padding-left: 9px;
                        padding-right: 9px;
                        Text {
                            text: root.fmt(tip.at-secs);
                            color: Theme.text-primary;
                            font-size: 11px;
                            font-weight: Typography.medium;
                            vertical-alignment: center;
                        }
                    }
                }
                // Caret — a small downward triangle under the bubble.
                Path {
                    width: 10px;
                    height: 6px;
                    fill: Theme.surface-elevated;
                    commands: "M 0 0 L 5 6 L 10 0 Z";
                    x: Math.round((parent.width - self.width) / 2 / 1px) * 1px;
                    y: parent.height - 1px;
                }
            }
        }
    }

    if root.show-times: VerticalLayout {
        alignment: center;
        Text {
            text: root.remaining;
            width: 44px;
            horizontal-alignment: left;
            color: Theme.text-muted;
            font-size: 11px;
        }
    }
}
