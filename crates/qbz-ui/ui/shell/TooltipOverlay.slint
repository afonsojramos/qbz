// Global hover-tooltip overlay — a single bubble (seek-bar style, downward
// caret) that renders ON TOP of everything. Mounted last in AppShell so no
// neighbour can cover it, and clamped to the window so it never clips at an
// edge (the caret still points at the real control). Driven by TooltipState,
// which each hoverable control fills with its text + absolute anchor on hover.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { TooltipState } from "../state.slint";

export component TooltipOverlay inherits Rectangle {
    // Fills the window; transparent and non-interactive (no TouchArea → clicks
    // pass through). root.width is the window width, used to clamp.
    property <length> bw: tip-layout.preferred-width;
    property <length> half: root.bw / 2;
    // Clamp the bubble centre so it stays fully on screen (8px margin).
    property <length> cx: Math.clamp(
        TooltipState.anchor-x,
        root.half + 8px,
        Math.max(root.half + 8px, root.width - root.half - 8px));

    visible: TooltipState.show && TooltipState.text != "";

    tip := Rectangle {
        x: root.cx - root.half;
        y: TooltipState.anchor-y - self.height - 9px;
        width: root.bw;
        // Height follows the content so a multi-line tooltip (e.g. the #638
        // Source/Output/cause stamp) fits without clipping, while a one-line
        // tooltip stays compact — never a fixed 3-line box.
        height: tip-layout.preferred-height;

        bubble := Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.surface-elevated;
            border-radius: 4px;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000099;
        }
        tip-layout := VerticalLayout {
            width: parent.width;
            padding-top: 5px;
            padding-bottom: 5px;
            padding-left: 9px;
            padding-right: 9px;
            Text {
                text: TooltipState.text;
                color: Theme.text-primary;
                font-size: 11px;
                font-weight: Typography.medium;
                horizontal-alignment: left;
            }
        }
        // Caret points at the real control centre even when the bubble is clamped.
        Path {
            width: 10px;
            height: 6px;
            fill: Theme.surface-elevated;
            x: Math.clamp(TooltipState.anchor-x - tip.x - self.width / 2,
                4px, tip.width - self.width - 4px);
            y: parent.height - 1px;
            commands: "M 0 0 L 5 6 L 10 0 Z";
        }
    }
}
