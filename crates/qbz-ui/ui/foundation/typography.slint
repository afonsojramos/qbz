// Typography scale — font sizes and weights.

export global Typography {
    // Small-preset font compensation. The interface-size preset scales the
    // whole window (SLINT_SCALE_FACTOR), so at Small (0.8) body text would
    // drop to 12px — too small. Rust seeds `boost = 1.1` for that preset
    // only (net body 15 × 0.8 × 1.1 ≈ 13.2px, readable); every other preset
    // keeps 1.0. Layout metrics take the full 0.8 on purpose — the extra
    // density is the point of Small.
    in-out property <float> boost: 1.0;
    out property <length> legal: 13px * boost;
    out property <length> link: 14px * boost;
    out property <length> body: 15px * boost;
    out property <length> subtitle: 15px * boost;
    out property <length> button: 17px * boost;
    // Canonical page / section title — Home section headings ("New
    // Releases", ...) and the hero titles on Album / Artist / Playlist
    // / Mixtape detail pages. One size for all, for consistency.
    out property <length> section: 18px * boost;
    out property <length> heading: 19px * boost;
    out property <length> title: 25px * boost;
    out property <length> wordmark: 29px * boost;

    out property <int> regular: 400;
    out property <int> medium: 500;
    out property <int> semibold: 600;
    out property <int> bold: 700;
}
