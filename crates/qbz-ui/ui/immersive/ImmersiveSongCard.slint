// Immersive song card — a 1:1 port of the Tauri `ImmersiveSongCard.svelte`.
//
// A MINIMAL bottom-right metadata card shown over the shader backgrounds
// (Plasma / Tunnel / Aurora): title + explicit + album·artist + quality badge,
// with the cover thumb on the RIGHT. NO transport / seek / heart — those live in
// the ImmersivePlayerBar. Reads NowPlayingState directly (no props, no new state,
// non-interactive), matching the Svelte source. The card is right-anchored at the
// mount site, so it grows LEFTWARD as its content gets wider.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { NowPlayingState } from "../state.slint";
import { QualityBadgeFull } from "../primitives/QualityBadgeFull.slint";

export component ImmersiveSongCard inherits Rectangle {
    // Content-sized: the card hugs its content (the parent pins it bottom-right,
    // so a wider card extends to the LEFT).
    width: row.preferred-width;
    height: row.preferred-height;

    row := HorizontalLayout {
        spacing: 12px;

        // Meta column (LEFT), right-aligned, sized to content.
        VerticalLayout {
            spacing: 3px;

            // Title (+ inline explicit chip), right-aligned. The title is capped
            // (it can be very long) and elides; the album·artist line below is NOT.
            HorizontalLayout {
                alignment: end;
                spacing: 6px;
                Rectangle {
                    width: Math.min(title-txt.preferred-width, 420px);
                    height: title-txt.preferred-height;
                    title-txt := Text {
                        width: 100%;
                        text: NowPlayingState.title;
                        color: Theme.text-primary;
                        font-size: 15px;
                        font-weight: Typography.semibold;
                        overflow: elide;
                        horizontal-alignment: right;
                    }
                }
                // Explicit "E" chip — 1:1 with TrackRow's badge.
                if NowPlayingState.explicit: Rectangle {
                    width: 16px;
                    height: 16px;
                    border-radius: 3px;
                    background: Theme.surface-elevated;
                    Text {
                        text: "E";
                        color: Theme.text-muted;
                        font-size: 9px;
                        font-weight: Typography.semibold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Subline: album (italic) · artist — FULL, never truncated. It sizes
            // to its content, so the whole card grows leftward to fit it.
            HorizontalLayout {
                alignment: end;
                spacing: 4px;
                if NowPlayingState.album != "": Text {
                    text: NowPlayingState.album;
                    color: #ffffff80;
                    font-size: 12px;
                    font-italic: true;
                }
                if NowPlayingState.album != "" && NowPlayingState.artist != "": Text {
                    text: "·";
                    color: #ffffff66;
                    font-size: 12px;
                }
                if NowPlayingState.artist != "": Text {
                    text: NowPlayingState.artist;
                    color: #ffffff99;
                    font-size: 12px;
                }
            }

            // Quality badge (full mode), right-aligned.
            HorizontalLayout {
                alignment: end;
                QualityBadgeFull {
                    tier: NowPlayingState.quality-tier;
                    detail: NowPlayingState.quality-detail;
                    show-icon: true;
                }
            }
        }

        // Cover thumb (RIGHT) — 72x72, rounded, drop-shadowed.
        Rectangle {
            width: 72px;
            height: 72px;
            border-radius: 6px;
            clip: true;
            drop-shadow-blur: 16px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 4px;
            Image {
                width: 100%;
                height: 100%;
                source: NowPlayingState.artwork;
                image-fit: cover;
            }
        }
    }
}
