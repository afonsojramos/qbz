// Switch toggle primitive — the standard on/off control for settings.
//
// The toggle does not flip itself: it emits `toggled(new-value)` and the
// caller updates the bound state. This keeps a single source of truth in
// the SettingsState global.

import { Theme } from "../foundation/semantic-colors.slint";

export component QbzToggle inherits Rectangle {
    in property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: root.checked ? Theme.accent : Theme.surface-elevated;
    opacity: root.enabled ? 1.0 : 0.4;

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: Theme.text-primary;
        y: 3px;
        x: root.checked ? root.width - self.width - 3px : 3px;
        animate x { duration: 120ms; easing: ease-out; }
    }

    TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if (root.enabled) {
                root.toggled(!root.checked);
            }
        }
    }

    // Keyboard activation: Enter/Space flip the switch, same as a click. The
    // TouchArea stays the pointer source; this only adds key activation + focus.
    fs := FocusScope {
        enabled: root.enabled;
        // See QbzPrimaryButton: declared after `ta`, hit-tested first;
        // focus-on-click:false stops it eating the first press (two-click bug).
        focus-on-click: false;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.toggled(!root.checked);
                return accept;
            }
            return reject;
        }
    }

    // Non-layout focus ring — transparent-bordered overlay shown only on
    // keyboard focus, matching the switch's pill radius so it never reflows.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: transparent;
        border-width: 2px;
        border-color: fs.has-focus ? Theme.focus-ring : transparent;
        border-radius: parent.border-radius;
    }
}
