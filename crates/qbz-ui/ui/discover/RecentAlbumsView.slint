// Recently Played Albums — the full-page listing opened from the Home
// rail's "View all". Renders the LOCAL play-history album store (capped at
// 24, see crate::recently) as a flat grid, so it carries none of the
// catalog-listing baggage: no pagination, no search, no error/retry branch
// (a local file read cannot fail into a retryable state — missing store =
// empty list). Template: AwardAlbumsView (fixed header + AlbumCollectionView
// inside a Flickable + the shared ListScrollbar), minus the search box and
// the infinite scroll.
//
// The grid reuses the Home rail's msgids (title + empty hint) — no new
// strings. Cards route through the shell's source-aware open-album funnel
// (Qobuz id vs local/Plex metadata group key), same as the rail.

import { Theme } from "../foundation/semantic-colors.slint";
import { Typography } from "../foundation/typography.slint";
import { RecentAlbumsState, NavState, ShellState } from "../state.slint";
import { AlbumCollectionView } from "AlbumCollectionView.slint";
import { LoadingSpinner } from "../primitives/LoadingSpinner.slint";
import { ListScrollbar } from "../primitives/ListScrollbar.slint";
import { NavButtons } from "../shell/NavButtons.slint";

export component RecentAlbumsView inherits Rectangle {
    callback open-album(string);
    callback open-artist(string);
    callback media-action(string, string, string);

    property <length> album-w: 200px;
    property <length> album-h: 266px;
    property <length> gap: 24px;

    background: Theme.surface-main;

    VerticalLayout {
        spacing: 0px;

        // --- Fixed header (always visible) -------------------------------
        // NavButtons + the page title on the LEFT, homologated with
        // AwardAlbumsView: the back/forward pair keeps the same screen
        // position as every page (center at y=25 = 11px top + 14px
        // half-button). Only the list below scrolls.
        Rectangle {
            height: 56px;
            background: Theme.surface-main;

            HorizontalLayout {
                x: 32px;
                y: 25px - self.height / 2;
                width: self.preferred-width;
                height: self.preferred-height;
                spacing: 16px;
                VerticalLayout {
                    alignment: center;
                    NavButtons { }
                }
                VerticalLayout {
                    alignment: center;
                    // Reused Home-rail msgid (discover.recentlyPlayedAlbums).
                    Text {
                        text: @tr("Recently Played Albums");
                        color: Theme.text-primary;
                        font-size: Typography.section;
                        font-weight: Typography.bold;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // --- Scrolling grid (only the listing scrolls) --------------------
        flick := Flickable {
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: page.preferred-height;
            // Scroll-position restore on back/forward (see nav::scope_for).
            property <string> sr-armed: NavState.restore-scope;
            function sr-restore() {
                if (NavState.restore-scope == "recent-albums" && self.viewport-height > self.height) {
                    self.viewport-y = NavState.scroll-restore;
                    NavState.restore-scope = "";
                }
            }
            init => { self.sr-restore(); }
            changed sr-armed => { self.sr-restore(); }
            changed viewport-height => { self.sr-restore(); }
            changed viewport-y => { NavState.report-scroll(self.viewport-y); }

            page := VerticalLayout {
                width: parent.width;
                padding-left: 32px;
                padding-right: 32px;
                padding-top: 8px;
                padding-bottom: 100px;
                spacing: 0px;
                alignment: start;

                // Loading spinner (the local read is near-instant; this only
                // flashes on the navigation frame).
                if RecentAlbumsState.loading: HorizontalLayout {
                    alignment: center;
                    VerticalLayout {
                        alignment: center;
                        spacing: 12px;
                        HorizontalLayout {
                            alignment: center;
                            LoadingSpinner { size: 36px; }
                        }
                        Text {
                            text: @tr("Loading…");
                            color: Theme.text-muted;
                            font-size: 14px;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Empty history — reuse the Home rail's placeholder hint.
                if !RecentAlbumsState.loading
                    && RecentAlbumsState.albums.length == 0: HorizontalLayout {
                    alignment: center;
                    Text {
                        text: @tr("Albums you play will appear here.");
                        color: Theme.text-muted;
                        font-size: 14px;
                    }
                }

                // --- Album grid (plain flat grid; no toolbar) -------------
                if !RecentAlbumsState.loading: AlbumCollectionView {
                    albums: RecentAlbumsState.albums;
                    view-mode: "grid";
                    is-grouped: false;
                    show-source: false;
                    card-width: root.album-w;
                    card-height: root.album-h;
                    card-gap: root.gap;
                    // Viewport windowing (element-count only; artwork is
                    // dispatched for the whole 24-card set up front, so a
                    // card mounting later picks its cover off the model).
                    // The offset is the page's padding-top (8px) — the
                    // spinner/empty branches are mutually exclusive with
                    // the grid, so nothing else sits above it.
                    windowed: true;
                    visible-top: -flick.viewport-y;
                    visible-height: flick.height;
                    content-offset: 8px;
                    open-album(id) => { root.open-album(id); }
                    open-artist(id) => { root.open-artist(id); }
                    media-action(kind, id, action) => {
                        root.media-action(kind, id, action);
                    }
                }
            }
        }
    }

    // Shared scrollbar in the right gutter (homologated cross-view). Sits
    // below the fixed 56px header so it tracks only the scrolling list.
    ListScrollbar {
        x: parent.width - self.width - 4px;
        y: 56px;
        width: 14px;
        height: parent.height - 56px;
        viewport-height: flick.viewport-height;
        visible-height: flick.height;
        viewport-y <=> flick.viewport-y;
        auto-hide: true;
        hover-active: ShellState.pointer-in-window
            && ShellState.pointer-x >= flick.absolute-position.x
            && ShellState.pointer-x <= flick.absolute-position.x + flick.width
            && ShellState.pointer-y >= flick.absolute-position.y
            && ShellState.pointer-y <= flick.absolute-position.y + flick.height;
    }
}
