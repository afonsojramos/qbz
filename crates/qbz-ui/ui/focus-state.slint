// Standalone leaf global for the hotkey text-input guard.
//
// Kept OUT of `state.slint` on purpose: `state.slint` imports structs from a
// few low-level primitives (e.g. `JumpNavTab` from `primitives/JumpNavBar.slint`),
// so those primitives CANNOT import `state.slint` back — that is a recursive
// import. This leaf has zero imports, so any file can import `UiFocusState`
// from here without a cycle. `state.slint` re-exports it for everyone else.

// Every free-text TextInput sets this on `changed has-focus`, so the global
// hotkey dispatcher ignores single-key shortcuts (Space, q, ?, 1-5, …) while
// the user is typing (mirrors the Tauri `isInputTarget` check).
export global UiFocusState {
    in-out property <bool> text-input-focused: false;
}
